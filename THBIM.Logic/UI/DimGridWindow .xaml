<Window x:Class="THBIM.FormDimStyle"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Dimension Style" Height="220" Width="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="#D9A566"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#C68C3E"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Padding" Value="15,6"/>
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryDark}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="10" BorderBrush="#CCC" BorderThickness="1" 
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Dimension Settings" FontSize="18" FontWeight="Bold" Foreground="#333"/>
                <TextBlock Text="Select the style for automatic dimensions" FontSize="12" Foreground="#888" Margin="0,2,0,0"/>
                <Separator Margin="0,10,0,0" Background="#EEE"/>
            </StackPanel>

            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <TextBlock Text="Dimension Type:" Foreground="#666" Margin="0,0,0,5" FontWeight="SemiBold"/>

                <ComboBox x:Name="cmbDimTypes" 
                          DisplayMemberPath="Name" 
                          Height="35" 
                          Padding="5"
                          FontSize="14"
                          VerticalContentAlignment="Center"
                          BorderBrush="#DDD">
                </ComboBox>

                <TextBlock Text="Note: Only Linear dimension styles are shown." 
                           FontSize="11" Foreground="#999" FontStyle="Italic" Margin="2,5,0,0"/>
                <TextBlock Text="ESC to Exit" 
                            FontSize="11" Foreground="#999" FontStyle="Italic" Margin="2,5,0,0" VerticalAlignment="Bottom"/>


            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Cancel" Background="Transparent" Foreground="#666" 
                        BorderThickness="0" Margin="0,0,10,0" Click="btnCancel_Click" Cursor="Hand"/>

                <Button Content="APPLY" Style="{StaticResource PrimaryButton}" 
                        Click="btnOk_Click" IsDefault="True" Width="80"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>