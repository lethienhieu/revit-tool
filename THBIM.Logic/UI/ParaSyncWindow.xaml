<Window x:Class="THBIM.ParaSyncWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="THBIM - Parameter Sync Pro" Height="700" Width="850"
        WindowStartupLocation="CenterScreen" Background="#FFF9F7F0" FontFamily="Segoe UI">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#FFE6D6B8" BorderThickness="1" CornerRadius="8" Background="White" Margin="0,0,0,10">
            <StackPanel Margin="15">
                <TextBlock Text="1. SELECT LINK INSTANCE" FontWeight="Bold" Foreground="#D9A566" Margin="0,0,0,10"/>
                <ComboBox x:Name="cbLinkInstance" Height="30" DisplayMemberPath="Name"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" BorderBrush="#FFE6D6B8" BorderThickness="1" CornerRadius="8" Background="White" Margin="0,0,0,10">
            <StackPanel Margin="15">
                <TextBlock Text="2. SELECT CATEGORIES" FontWeight="Bold" Foreground="#D9A566" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Source (Link):" FontSize="11" Foreground="#888"/>
                        <ComboBox x:Name="cbLinkCategory" Height="30"/>
                    </StackPanel>
                    <TextBlock Text="➔" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,5" FontSize="18"/>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Target (Host):" FontSize="11" Foreground="#888"/>
                        <ComboBox x:Name="cbHostCategory" Height="30"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" BorderBrush="#FFE6D6B8" BorderThickness="1" CornerRadius="8" Background="White" Margin="0,0,0,10">
            <StackPanel Margin="15">
                <TextBlock Text="3. MATCHING METHOD" FontWeight="Bold" Foreground="#D9A566" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="rbCoordinate" Content="Direct Alignment (Center-to-Center)" IsChecked="True" Margin="0,0,30,0"/>
                    <RadioButton x:Name="rbPileCap" Content="Via Host Geometry (Intersection)"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" BorderBrush="#FFE6D6B8" BorderThickness="1" CornerRadius="8" Background="White">
            <DockPanel>
                <Border Background="#D9A566" DockPanel.Dock="Top" Height="30">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SOURCE PARAMETER (LINK)" Foreground="White" VerticalAlignment="Center" Margin="10,0" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="TARGET PARAMETER (HOST)" Foreground="White" VerticalAlignment="Center" Margin="10,0" FontWeight="Bold"/>
                    </Grid>
                </Border>
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="icParamMapping">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" ItemsSource="{Binding LinkParams}" SelectedItem="{Binding SelectedLinkParam}" Height="25" Margin="0,0,5,0"/>
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding HostParams}" SelectedItem="{Binding SelectedHostParam}" Height="25" Margin="5,0,0,0"/>
                                        <Button Grid.Column="2" Content="✕" Click="BtnRemoveRow_Click" Cursor="Hand" Background="#F2F2F2" BorderThickness="0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Button Grid.Row="1" Content="+ Add Mapping Pair" Click="BtnAddRow_Click" HorizontalAlignment="Left" Margin="0,10,0,0" Padding="15,5" Background="#5F8670" Foreground="White" BorderThickness="0"/>
                </Grid>
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="CANCEL" Width="100" Margin="0,0,10,0" IsCancel="True" Background="#95A5A6" Foreground="White" BorderThickness="0"/>
            <Button Content="PICK OBJECTS &amp; APPLY" Width="220" Height="45" Background="#D9A566" Foreground="White" Click="BtnExecute_Click" FontWeight="Bold" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>