<Window x:Class="THBIM.Tools.ColumnPlanDimWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="THBIM - AUTO DIM COLUMNS" Height="600" Width="860"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#FFFDF7E6">

    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="#E2B76A"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#C69A4E"/>
        <SolidColorBrush x:Key="CardBg" Color="#FFFFFBF2"/>
        <SolidColorBrush x:Key="Stroke" Color="#CCB589"/>
        <SolidColorBrush x:Key="Text" Color="#333333"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="BorderBrush" Value="{StaticResource Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="CornerRadius" Value="10,10,0,0"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#FFD9C497"/>
                                <Setter Property="BorderBrush" Value="#FFD1B67F"/>
                                <Setter Property="Foreground" Value="#88FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="UnderlineTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0,0,0,4"/>
                            <Rectangle x:Name="Underline" Height="1.5" VerticalAlignment="Bottom"
                                       Fill="{StaticResource Stroke}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Underline" Property="Height" Value="2.5"/>
                                <Setter TargetName="Underline" Property="Fill" Value="{StaticResource Primary}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                                <Setter TargetName="Underline" Property="Fill" Value="#D9CBAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UnderlineDropBox" TargetType="ComboBox">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                          BorderThickness="0" Padding="0">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="Transparent">
                                                        <Path Data="M 0 0 L 8 0 L 4 5 Z" 
                                                              Fill="{StaticResource PrimaryDark}" 
                                                              HorizontalAlignment="Right" 
                                                              VerticalAlignment="Center" 
                                                              Margin="0,0,6,0"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>

                            <ContentPresenter Margin="4,2,24,4"
                                              IsHitTestVisible="False"
                                              HorizontalAlignment="Left" VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>

                            <Rectangle x:Name="Underline" Height="1.5" VerticalAlignment="Bottom"
                                       Fill="{StaticResource Stroke}"/>

                            <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="White" BorderBrush="{StaticResource Stroke}" BorderThickness="1"
                                        CornerRadius="8" Padding="2" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Underline" Property="Height" Value="2.5"/>
                                <Setter TargetName="Underline" Property="Fill" Value="{StaticResource Primary}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                                <Setter TargetName="Underline" Property="Fill" Value="#D9CBAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SideToggle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="box" Width="18" Height="18" CornerRadius="3"
                                BorderBrush="{StaticResource PrimaryDark}" BorderThickness="2"
                                Background="White">
                            <Path x:Name="tick" Data="M2,9 L7,14 L16,4"
                                  Stroke="{StaticResource PrimaryDark}" StrokeThickness="2.4"
                                  StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                  Visibility="Collapsed"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="tick" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="box" Property="Background" Value="#FFF5E8C9"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource Primary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource SectionHeader}">
                    <TextBlock Text="Settings" Foreground="White" FontWeight="SemiBold"/>
                </Border>

                <StackPanel Grid.Row="1" Margin="0,10,0,0">

                    <TextBlock Text="Dimension Type" FontWeight="SemiBold"/>
                    <ComboBox x:Name="cboDimType" Style="{StaticResource UnderlineDropBox}"
                              DisplayMemberPath="Name" Margin="0,0,0,15"/>

                    <StackPanel Margin="0,0,0,15">
                        <CheckBox x:Name="chkDimCOL" IsChecked="True" Content="Column Dimensions" FontWeight="SemiBold"/>

                        <DockPanel LastChildFill="False" Margin="0,5,0,0">
                            <DockPanel.Style>
                                <Style TargetType="DockPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, ElementName=chkDimCOL}" Value="False">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DockPanel.Style>

                            <StackPanel DockPanel.Dock="Left" Width="220">
                                <TextBlock Text="Column Offset (mm)"/>
                                <TextBox x:Name="txtOffsetChain" Text="700">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource UnderlineTextBox}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecked, ElementName=chkAutoChain}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                <CheckBox x:Name="chkAutoChain" IsChecked="True" Content="Auto" Margin="12,0,0,6"/>
                            </StackPanel>
                        </DockPanel>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,15">
                        <CheckBox x:Name="chkDimGrid" IsChecked="True" Content="Grid Dimensions" FontWeight="SemiBold"/>

                        <DockPanel LastChildFill="False" Margin="0,5,0,0">
                            <DockPanel.Style>
                                <Style TargetType="DockPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, ElementName=chkDimGrid}" Value="False">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DockPanel.Style>

                            <StackPanel DockPanel.Dock="Left" Width="220">
                                <TextBlock Text="Grid Offset (mm)"/>
                                <TextBox x:Name="txtOffsetGrid" Text="700">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox" BasedOn="{StaticResource UnderlineTextBox}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChecked, ElementName=chkAutoGrid}" Value="True">
                                                    <Setter Property="IsEnabled" Value="False"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                <CheckBox x:Name="chkAutoGrid" IsChecked="True" Content="Auto" Margin="12,0,0,6"/>
                            </StackPanel>
                        </DockPanel>
                    </StackPanel>

                    <StackPanel Margin="0,25,0,0">

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="Tag Column" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <CheckBox x:Name="chkTag" IsChecked="False" VerticalAlignment="Center"/>
                        </StackPanel>

                        <ComboBox x:Name="cboTagType" Margin="0,0,0,5"
          DisplayMemberPath="Name">
                            <ComboBox.Style>
                                <Style TargetType="ComboBox" BasedOn="{StaticResource UnderlineDropBox}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, ElementName=chkTag}" Value="False">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.Style>

                        </ComboBox>

                        <DockPanel LastChildFill="True">
                            <TextBlock Text="Pos:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="Gray"/>
                            <ComboBox x:Name="cboTagPos" SelectedIndex="0" Style="{StaticResource UnderlineDropBox}">
                                <ComboBoxItem Content="Top-Right" Tag="TR"/>
                                <ComboBoxItem Content="Top-Left" Tag="TL"/>
                                <ComboBoxItem Content="Bottom-Right" Tag="BR"/>
                                <ComboBoxItem Content="Bottom-Left" Tag="BL"/>
                                <ComboBoxItem Content="Center" Tag="C"/>
                            </ComboBox>

                            <DockPanel.Style>
                                <Style TargetType="DockPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChecked, ElementName=chkTag}" Value="False">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Setter Property="Opacity" Value="0.5"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DockPanel.Style>
                        </DockPanel>

                    </StackPanel>

                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Rectangle Fill="{StaticResource Stroke}" Width="1" HorizontalAlignment="Center" RadiusX="1" RadiusY="1"/>
        </Grid>

        <Border Grid.Column="2" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource SectionHeader}">
                    <TextBlock Text="Placement" Foreground="White" FontWeight="SemiBold"/>
                </Border>

                <Grid Grid.Row="1" Margin="0,10,0,12">
                    <Border Background="#FFF8F1DE" CornerRadius="12" BorderBrush="{StaticResource Stroke}" BorderThickness="1"/>
                    <Grid>
                        <Image x:Name="imgX"
                               Width="360" Height="260" Stretch="Uniform"
                               Source="/Resources/preview_dim_x.png"/>

                        <Image x:Name="imgY"
                               Width="360" Height="260" Stretch="Uniform"
                               Source="/Resources/preview_dim_y.png"/>
                    </Grid>

                    <RadioButton x:Name="optTop"    GroupName="TopBottom"  Style="{StaticResource SideToggle}"
                                 HorizontalAlignment="Center" VerticalAlignment="Top"    Margin="0,8,0,0" IsChecked="True"/>
                    <RadioButton x:Name="optBottom" GroupName="TopBottom"  Style="{StaticResource SideToggle}"
                                 HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,8"/>
                    <RadioButton x:Name="optLeft"   GroupName="LeftRight"  Style="{StaticResource SideToggle}"
                                 HorizontalAlignment="Left"   VerticalAlignment="Center" Margin="10,0,0,0" IsChecked="True" />
                    <RadioButton x:Name="optRight"  GroupName="LeftRight"  Style="{StaticResource SideToggle}"
                                 HorizontalAlignment="Right"  VerticalAlignment="Center" Margin="0,0,10,0" />
                </Grid>

                <Grid Grid.Row="2" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="btnRun" Grid.Column="1" Content="Run (0/0)" Height="44" Grid.ColumnSpan="2" Margin="8,0,3,0"/>

                    <Rectangle Grid.Column="1" Width="1" Fill="Transparent"/>
                    
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>