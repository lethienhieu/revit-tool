<Window x:Class="THBIM.CombineParamWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        
        xmlns:local="clr-namespace:THBIM"
        
        mc:Ignorable="d"
        Title="THBIM - Multi-Category Combiner"
        Height="600" Width="1100"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen"
        Background="#FFF9F7F0"
        FontFamily="Segoe UI">

    <Window.Resources>
        <local:InverseBoolConverter x:Key="InverseBoolConverter" />

        <SolidColorBrush x:Key="Primary" Color="#D9A566"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#C68C3E"/>
        <SolidColorBrush x:Key="TextGray" Color="#555555"/>
        <SolidColorBrush x:Key="LightBorder" Color="#FFE6D6B8"/>

        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#999" BlurRadius="10" ShadowDepth="2" Opacity="0.25"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderBar" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="CornerRadius" Value="8,8,0,0"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#B5803B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#DDD"/>
                                <Setter Property="Foreground" Value="#AAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F2F2F2"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#999"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E6E6E6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#F9F9F9"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#EEE"/>
                                <Setter Property="Foreground" Value="#CCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionCard}">
                <DockPanel>
                    <Border Style="{StaticResource HeaderBar}" DockPanel.Dock="Top">
                        <DockPanel>
                            <TextBlock Text="1. Scope" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                            <CheckBox x:Name="chkAll" Content="All Categories" 
                                      IsChecked="{Binding IsAllCategories, Mode=TwoWay}"
                                      Foreground="White" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"
                                      FlowDirection="RightToLeft"/>
                        </DockPanel>
                    </Border>

                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" 
                                      IsEnabled="{Binding IsChecked, ElementName=chkAll, Converter={StaticResource InverseBoolConverter}}">
                            <ItemsControl ItemsSource="{Binding SelectedCategoryRows}" x:Name="icCategories">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <ComboBox Grid.Column="0" Height="28"
                                                      ItemsSource="{Binding DataContext.AllCategoriesList, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                                      DisplayMemberPath="Name"
                                                      IsTextSearchEnabled="True" TextSearch.TextPath="Name"/>

                                            <Button Grid.Column="1" Content="✕" Width="28" Margin="5,0,0,0" Click="BtnRemoveCat_Click"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Button Grid.Row="1" Content="+ Add Category" Style="{StaticResource SecondaryButton}" 
                                Margin="0,10,0,0" Click="BtnAddCat_Click"
                                IsEnabled="{Binding ElementName=chkAll, Path=IsChecked, Converter={StaticResource InverseBoolConverter}}"/>
                    </Grid>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource SectionCard}">
                <DockPanel>
                    <Border Style="{StaticResource HeaderBar}" DockPanel.Dock="Top">
                        <TextBlock Text="2. Input Parameters" Foreground="White" FontWeight="Bold"/>
                    </Border>

                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding SourceParameters}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <ComboBox Grid.Column="0" Height="28"
                                                      ItemsSource="{Binding DataContext.SourceParamList, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      SelectedItem="{Binding SelectedParam, Mode=TwoWay}"
                                                      DisplayMemberPath="Name"
                                                      IsEditable="True" IsTextSearchEnabled="True" TextSearch.TextPath="Name"/>

                                            <Button Grid.Column="1" Content="✕" Width="28" Margin="5,0,0,0" Click="BtnRemoveParam_Click"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <DockPanel Grid.Row="1" Margin="0,10,0,0">
                            <Border DockPanel.Dock="Right" CornerRadius="4" BorderBrush="{StaticResource Primary}" BorderThickness="1" Width="50" Margin="10,0,0,0">
                                <TextBox Text="{Binding Separator, UpdateSourceTrigger=PropertyChanged}" 
                                         FontWeight="Bold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" BorderThickness="0" Background="Transparent"/>
                            </Border>
                            <Button Content="+ Add Parameter" Style="{StaticResource SecondaryButton}" Click="BtnAddParam_Click"/>
                        </DockPanel>
                    </Grid>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SectionCard}">
                <DockPanel>
                    <Border Style="{StaticResource HeaderBar}" DockPanel.Dock="Top">
                        <TextBlock Text="3. Target &amp; Result" Foreground="White" FontWeight="Bold"/>
                    </Border>

                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Target Parameter (Text Only):" Foreground="#555" Margin="0,0,0,5"/>
                        <ListBox Grid.Row="1" ItemsSource="{Binding TargetParamList}" 
                                 SelectedItem="{Binding TargetParameter, Mode=TwoWay}"
                                 DisplayMemberPath="Name" BorderBrush="#DDD" BorderThickness="1"/>

                        <TextBlock Grid.Row="2" Text="Preview:" FontWeight="Bold" Margin="0,10,0,5" Foreground="{StaticResource PrimaryDark}"/>
                        <TextBox Grid.Row="3" Text="{Binding PreviewResult, Mode=OneWay}" 
                                 IsReadOnly="True" Background="#F5F5F5" Height="60" TextWrapping="Wrap" Padding="5"/>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="5,10">
            <Button HorizontalAlignment="Right" Content="APPLY TO PROJECT" Style="{StaticResource PrimaryButton}" Width="150" Height="40" Click="BtnExecute_Click"/>
            <Button HorizontalAlignment="Left" Content="Close" Style="{StaticResource SecondaryButton}" Width="100" IsCancel="True"/>
        </Grid>
    </Grid>
</Window>