<Window x:Class="OPENING.OPENING"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OPENING"
        Height="680" Width="850"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI"
        Background="#FFF9F7F0">

    <Window.Resources>
        <!-- ========= Palette ========= -->
        <SolidColorBrush x:Key="Primary"     Color="#D9A566"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#C68C3E"/>
        <SolidColorBrush x:Key="TextMain"    Color="#2E2E2E"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#6E6E6E"/>
        <SolidColorBrush x:Key="CardBorder"  Color="#E6D6B8"/>
        <SolidColorBrush x:Key="CardBg"      Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="SoftBg"      Color="#FFF5EFE1"/>

        <!-- ========= Buttons ========= -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Background" Value="#FFF5EFE1"/>
            <Setter Property="Foreground" Value="#7A5A2A"/>
            <Setter Property="BorderBrush" Value="#E7D1AC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- ========= Underlined TextBox ========= -->
        <Style x:Key="UnderlinedTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0,0,0,1"/>
                            <Border VerticalAlignment="Bottom" BorderBrush="#CFCFCF" BorderThickness="0,0,0,1"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========= Section Header ========= -->
        <Style x:Key="SectionHeader" TargetType="Border">
            <Setter Property="Background" Value="#FFF3E6CF"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- ========= Card / Panel ========= -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <!-- ========= SectionCard + HeaderBar (cho Revit Links) ========= -->
        <Style x:Key="SectionCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="HeaderBar" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="CornerRadius" Value="8,8,0,0"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <!-- ========= ComboBox ========= -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <!-- Small label tag -->
        <Style x:Key="Chip" TargetType="Border">
            <Setter Property="Background" Value="#FFF3E6CF"/>
            <Setter Property="BorderBrush" Value="#EBDAB9"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>

    <!-- ===================== Layout ===================== -->
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="18"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== LEFT: Inputs ===== -->
        <StackPanel Grid.Column="0">

            <Border Style="{StaticResource SectionHeader}">
                <TextBlock Text="Pick Family" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextMain}"/>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <ComboBox x:Name="cbOpeningType" SelectedIndex="0" SelectionChanged="cbOpeningType_SelectionChanged">
                        <ComboBoxItem Content=""/>
                        <ComboBoxItem Content="TH_ROUND_SLEEVE"/>
                        <ComboBoxItem Content="TH_RECTANGULAR_SLEEVE"/>
                        <ComboBoxItem Content="TH_RECTANGULAR_MULTI_SLEEVE"/>
                    </ComboBox>

                    <Border Style="{StaticResource Chip}" Margin="0,8,0,0">
                        <TextBlock Text="Parameters" FontWeight="SemiBold" />
                    </Border>

                    <TextBlock Text="Clearance (mm)" Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/>
                    <TextBox x:Name="txtClearance" Style="{StaticResource UnderlinedTextBox}" Text="10" TextChanged="UpdatePreview"/>

                    <TextBlock Text="Extrusion (mm)" Foreground="{StaticResource TextMuted}" Margin="0,8,0,0"/>
                    <TextBox x:Name="txtExtrusion" Style="{StaticResource UnderlinedTextBox}" Text="20" TextChanged="UpdatePreview"/>

                    <TextBlock Text="Fill (mm)" Foreground="{StaticResource TextMuted}" Margin="0,8,0,0"/>
                    <TextBox x:Name="txtFill" Style="{StaticResource UnderlinedTextBox}" Text="25" TextChanged="UpdatePreview"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button x:Name="btnLoad" Content="Load Family" Style="{StaticResource GhostButton}" Click="btnLoad_Click"/>
                        <Button x:Name="btnRunCommand" Content="Create Opening" Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}" Click="btnRun_Click"/>
                    </StackPanel>

                    <!-- (2) Revit Links -->
                    <Border Style="{StaticResource SectionCard}" Margin="0,14,0,0">
                        <DockPanel>
                            <Border Style="{StaticResource HeaderBar}" DockPanel.Dock="Top">
                                <TextBlock Text="Select Revit Link Files" Foreground="White" FontWeight="Bold"/>
                            </Border>

                            <StackPanel Margin="14">
                                <TextBlock Text="Select the link files to use:" Margin="0,0,0,6" Foreground="{StaticResource TextMuted}"/>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                                    <StackPanel x:Name="spLinks"/>
                                </ScrollViewer>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ===== RIGHT: Scoreboard + Preview ===== -->
        <StackPanel Grid.Column="2">

            <Border Style="{StaticResource SectionHeader}">
                <TextBlock Text="Statistics" FontWeight="SemiBold"/>
            </Border>

            <UniformGrid Columns="6" Margin="0,0,0,10">
                <Border Style="{StaticResource Card}" Padding="10" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="DuctsOpn" Foreground="#7A5A2A" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding DuctsCount}" FontSize="30" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="10" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="PipesOpn" Foreground="#7A5A2A" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding PipesCount}" FontSize="30" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="10" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="CblTrysOpn" Foreground="#7A5A2A" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding CableTraysCount}" FontSize="30" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="10" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="CnduitsOpn" Foreground="#7A5A2A" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding ConduitsCount}" FontSize="30" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="10" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="MultiOpn" Foreground="#7A5A2A" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding MultiCount}" FontSize="30" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Padding="10">
                    <StackPanel>
                        <TextBlock Text="TotalOpn" Foreground="#7A5A2A" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalCount}" FontSize="30" FontWeight="Bold"
                                   Foreground="#2E7D32"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Preview (Canvas ve dong) -->
            <Border Style="{StaticResource Card}" Padding="14" Margin="0,0,0,0">
                <Border Background="White" BorderBrush="#E9E0A7" BorderThickness="1"
                        CornerRadius="10" Width="500" Height="320"
                        HorizontalAlignment="Center" ClipToBounds="True">
                    <Canvas x:Name="cvsPreview" Width="500" Height="320" ClipToBounds="True" Background="Transparent"/>
                </Border>
            </Border>
        </StackPanel>

    </Grid>
</Window>
