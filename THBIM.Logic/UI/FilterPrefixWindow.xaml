<Window x:Class="colorslapsher.UI.FilterPrefixWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Filter Naming" Height="200" Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="#D9A566"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#C68C3E"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Padding" Value="15,6"/>
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryDark}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="10" BorderBrush="#CCC" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Define Filter Name Format" FontSize="16" FontWeight="Bold" Foreground="#333"/>

            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <TextBlock Text="Enter Prefix:" Foreground="#666" Margin="0,0,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="txtPrefix" Text="WH" Padding="5" FontSize="14" BorderBrush="#CCC" VerticalContentAlignment="Center"/>

                    <TextBlock Grid.Column="1" Text="_Value" FontSize="14" Foreground="#999" VerticalAlignment="Center" Margin="5,0,0,0" FontStyle="Italic"/>
                </Grid>

                <TextBlock Text="Example result: WH_Level 1" FontSize="11" Foreground="#888" Margin="2,5,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Cancel" Background="Transparent" Foreground="#666" BorderThickness="0" Margin="0,0,10,0" Click="btnCancel_Click" Cursor="Hand"/>
                <Button Content="CREATE" Style="{StaticResource PrimaryButton}" Click="btnOK_Click" IsDefault="True" Width="63"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>