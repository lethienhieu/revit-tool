<Window x:Class="HangerGenerator.SupportGeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hanger Generator"
        Height="540" Width="850"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFFDECB2">
    <Window.Resources>
        <!-- Button Style: chỉ set BorderRadius nếu custom template, còn lại bỏ đi -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#FFE5C36F"/>
            <Setter Property="Foreground" Value="#FF212121"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="BorderBrush" Value="#FFD6B54A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Color="#2A888888"/>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Soft Border for Panels (vẫn giữ CornerRadius) -->
        <Style x:Key="SoftBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="BorderBrush" Value="#FFE1B928"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="#FFFEF8D6"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#1A000000"/>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FFD1A631"/>
            <Setter Property="Background" Value="#FFFDF6CF"/>
            <!-- BỎ CornerRadius -->
        </Style>
        <!-- ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FFD1A631"/>
            <Setter Property="Background" Value="#FFFDF6CF"/>
            <!-- BỎ CornerRadius -->
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="30"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Input Panel -->
        <Border Grid.Column="0" Style="{StaticResource SoftBorder}" Padding="20" VerticalAlignment="Top">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="PICK SUPPORT:" Margin="0,0,0,8" FontWeight="Bold" FontSize="16"/>
                <ComboBox x:Name="cbSupportType" SelectedIndex="0" SelectionChanged="cbSupportType_SelectionChanged">
                    <ComboBoxItem Content="TH_Pipe Support Omega"/>
                    <ComboBoxItem Content="TH_Foam Pipe Clamp"/>
                    <ComboBoxItem Content="TH_U_Bolt"/>
                    <ComboBoxItem Content="TH_DA_U_Steel_Thread Rod"/>
                    <ComboBoxItem Content="TH_DA_V_Steel_Thread Rod"/>
                    <ComboBoxItem Content="TH_DA_U_Steel_Foundation"/>
                </ComboBox>

                <!-- Bọc 2 TextBlock + 2 TextBox vào border màu xanh lá nhạt -->
                <Border Background="#FFDFFDE2" CornerRadius="14" BorderBrush="#FF88B694" BorderThickness="1" Margin="0,16,0,16">
                    <StackPanel Margin="12">
                        <Border Background="#FFE2FFD7" BorderBrush="#EADDE5" BorderThickness="1" CornerRadius="8" Padding="6,2" Margin="0,0,0,6">
                            <TextBlock Text="A - mm" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        </Border>
                        <TextBox x:Name="txtOffsetA" Text="200"/>

                        <Border Background="#FFE2FFD7" BorderBrush="#FF63BE7B" BorderThickness="1" CornerRadius="8" Padding="6,2" Margin="0,8,0,6">
                            <TextBlock Text="B - mm" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBox x:Name="txtSpacingB" Text="3000"/>
                    </StackPanel>
                </Border>

                <!-- NEW: CheckBox LAYER 2 (đặt ngay dưới cụm A/B) -->
                <Border Background="#FFE2FFD7" BorderBrush="#FF63BE7B" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,10">
                    <CheckBox x:Name="chkLayer2"
                              Content="LAYER 2"
                              FontWeight="SemiBold"
                              VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Steel Type" Margin="0,0,0,3" FontWeight="SemiBold" />
                <TextBox x:Name="txtSteelType" IsEnabled="False" BorderBrush="#FF63BE7B" />
                
                <Button x:Name="btnLoad" Content="Load Family" Style="{StaticResource ModernButton}" Click="btnLoad_Click"/>
                <Button x:Name="btnRunCommand" Content="CREATE SUPPORT" Style="{StaticResource ModernButton}" Click="btnRun_Click"/>
            </StackPanel>
        </Border>

        <!-- Preview Image Panel (Không bo góc) -->
        <Border Grid.Column="2"
                BorderBrush="#FFD4B100"
                BorderThickness="4"
                Background="#FFFEF8D6"
                Padding="16"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Width="500" Height="320"
                Margin="0,0,0,44">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="4" Color="#44303030" Opacity="0.8"/>
            </Border.Effect>
            <Image x:Name="imgPreview"
                   Stretch="Uniform" Margin="-16,-15,-15,-16"/>

        </Border>
        
    </Grid>
</Window>
