<Window x:Class="THBIM.UI.DroppanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="THBIM - Auto Drop Panel &amp; Pile Cap" Height="550" Width="750"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="MainButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#D49A6A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E5AA7A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect Color="Black" Direction="320" ShadowDepth="0" Opacity="0.1" BlurRadius="10"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#D49A6A" CornerRadius="10,10,0,0" Padding="15">
                    <TextBlock Text="1. Select Category &amp; Family" Foreground="White" FontWeight="Bold" FontSize="16"/>
                </Border>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,15,20,5">
                    <RadioButton x:Name="rbModeDropPanel" Content="Drop Panel" IsChecked="True" 
                                 FontWeight="Bold" GroupName="ModeGroup" Checked="Mode_Checked"/>
                    <RadioButton x:Name="rbModePileCap" Content="Pile Cap" Margin="20,0,0,0" 
                                 FontWeight="Bold" GroupName="ModeGroup" Checked="Mode_Checked"/>
                </StackPanel>

                <TextBlock Grid.Row="2" Text="Available Types:" Foreground="#666" Margin="20,10,20,5"/>

                <Border Grid.Row="3" Margin="20,5,20,5" BorderBrush="#EEE" BorderThickness="1" CornerRadius="5">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="5">
                        <StackPanel x:Name="spFraming"/>
                    </ScrollViewer>
                </Border>

                <Button x:Name="btnPick" Grid.Row="4" Content="PICK COLUMNS &amp; FLOORS" Margin="20,5,20,20" Height="40"
                        Background="White" BorderBrush="#DDD" BorderThickness="1" Click="btnPick_Click"/>
            </Grid>
        </Border>

        <Border Grid.Column="2" Background="White" CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect Color="Black" Direction="320" ShadowDepth="0" Opacity="0.1" BlurRadius="10"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#D49A6A" CornerRadius="10,10,0,0" Padding="15">
                    <TextBlock Text="2. Placement Settings" Foreground="White" FontWeight="Bold" FontSize="16"/>
                </Border>

                <StackPanel x:Name="grpPlacementMethod" Grid.Row="1" Margin="20">
                    <TextBlock Text="Placement Method:" FontWeight="Bold" Foreground="#444" Margin="0,0,0,10"/>

                    <CheckBox x:Name="chkLineMode" Content="Line-based Mode" 
                              IsChecked="True" FontWeight="Bold" Foreground="#333"
                              Checked="chkLineMode_CheckedChanged" Unchecked="chkLineMode_CheckedChanged"/>

                    <TextBlock Text="Use this for Structural Framing families that require a Start/End point." 
                               FontSize="10" Foreground="#888" Margin="20,2,0,15" TextWrapping="Wrap"/>

                    <StackPanel x:Name="pnlLengthInput">
                        <TextBlock Text="Panel Length (mm):" FontWeight="Bold" Foreground="#D49A6A"/>
                        <TextBox x:Name="txtLength" Height="35" VerticalContentAlignment="Center" Padding="5" 
                                 Text="2500" FontWeight="Bold" BorderBrush="#D49A6A" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Separator Margin="0,20"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="20,0,20,0" VerticalAlignment="Top">
                    <TextBlock Text="Intersections Found:" Foreground="#666"/>
                    <TextBlock x:Name="txtCount" Text="0 items" FontSize="28" FontWeight="Bold" Foreground="#D49A6A" Margin="0,5,0,0"/>
                </StackPanel>

                <Button x:Name="btnCreate" Grid.Row="3" Content="CREATE" 
                        Style="{StaticResource MainButtonStyle}"
                        Margin="20,0,20,20" Height="50" Click="btnCreate_Click" IsEnabled="False"/>
            </Grid>
        </Border>
    </Grid>
</Window>