<Window x:Class="THBIM.MultiCategoryExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="THBIM - Multi-Category Export" Height="750" Width="1300"
        WindowStartupLocation="CenterScreen" Background="#FFF9F7F0" 
        FontFamily="Segoe UI" FontSize="11">

    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="#D9A566"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#C68C3E"/>

        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="BorderBrush" Value="#AAA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryDark}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F2F2F2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <StackPanel Margin="2">
                <ItemsControl ItemsSource="{Binding CategoryTables}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource SectionCard}">
                                <DockPanel>
                                    <Border Background="#C6E0B4" BorderBrush="#AAA" BorderThickness="0,0,0,1" Padding="3" DockPanel.Dock="Top">
                                        <StackPanel Orientation="Horizontal">

                                            <Grid Width="360" Margin="0,0,2,0" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">

                                                    <Grid Margin="0,0,2,0">
                                                        <ComboBox Width="95" Height="22" ItemsSource="{Binding AvailableCategories}" SelectedItem="{Binding SelectedCategory}"/>
                                                        <TextBlock Text="Category..." IsHitTestVisible="False" Foreground="#777" FontStyle="Italic" VerticalAlignment="Center" Margin="6,0,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding SelectedCategory}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>

                                                    <TextBlock Text=" L.Param: " FontWeight="Bold" Foreground="Blue" VerticalAlignment="Center" Margin="0,0,2,0" ToolTip="Chọn Parameter quản lý Level"/>
                                                    <ComboBox Width="85" Height="22" ItemsSource="{Binding AvailableLevelParameters}" SelectedItem="{Binding SelectedLevelParameter}" ToolTip="Parameter quản lý Level"/>

                                                    <TextBlock Text=" Lv: " FontWeight="Bold" Foreground="Blue" VerticalAlignment="Center" Margin="2,0,2,0"/>
                                                    <ComboBox Width="55" Height="22" ItemsSource="{Binding ParentVM.AvailableLevels}" SelectedItem="{Binding SelectedLevelValue}"/>

                                                    <Button Content="Fields..." Width="50" Height="22" Margin="5,0,0,0" Background="#E2F0D9" BorderBrush="#70AD47" BorderThickness="1" FontWeight="Bold" Foreground="#385723" Cursor="Hand" ToolTip="Select Parameters" Command="{Binding EditFieldsCommand}"/>
                                                </StackPanel>
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding Columns}" VerticalAlignment="Center">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Width="110" Margin="0,0,2,0" VerticalAlignment="Center">
                                                            <TextBox Height="22" Text="{Binding Heading, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding ParameterName}" Background="#EEE" BorderBrush="#AAA" FontWeight="Bold" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <TextBlock Text="Notes" Width="160" Margin="8,0,0,0" FontWeight="Bold" VerticalAlignment="Center" TextAlignment="Center" Height="22"/>
                                            <Button Content="✕ remove table" Height="22" Margin="15,0,0,0" Padding="5,0" Background="Transparent" Foreground="Red" BorderBrush="Red" BorderThickness="1" Cursor="Hand" Command="{Binding ParentVM.RemoveTableCommand}" CommandParameter="{Binding}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <Grid Margin="3">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <ItemsControl Grid.Row="0" ItemsSource="{Binding Rows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,1">
                                                        <Grid Width="360" Margin="0,0,2,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <ComboBox Grid.Column="0" Height="22" ItemsSource="{Binding ParentTable.MainParameterValues}" SelectedItem="{Binding MainParameterValue}"/>
                                                            <Button Grid.Column="1" Content="✕" Width="22" Margin="2,0,5,0" Background="#FFEAEA" BorderBrush="#FFCCCC" BorderThickness="1" Foreground="Red" Command="{Binding ParentTable.RemoveRowCommand}" CommandParameter="{Binding}"/>
                                                        </Grid>

                                                        <ItemsControl ItemsSource="{Binding Cells}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal"/>
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Width="110" Margin="0,0,2,0" BorderBrush="#E0E0E0" BorderThickness="1" Background="White">
                                                                        <TextBox Height="22" Text="{Binding CellValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" BorderThickness="0" Background="Transparent" Foreground="Black" Padding="0"/>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                        <TextBox Width="160" Margin="3,0,0,0" Height="22" Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" BorderBrush="#CCC" Padding="2,0" VerticalContentAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,1,0,3">
                                            <Button Content="+ Add Row" Style="{StaticResource SecondaryButton}" Height="22" Command="{Binding AddRowCommand}" Margin="0,0,5,0"/>
                                            <Button Content="All" Style="{StaticResource SecondaryButton}" Height="22" Width="40" Command="{Binding AddAllRowsCommand}" FontWeight="Bold" Foreground="#385723" BorderBrush="#70AD47" Background="#E2F0D9" ToolTip="Add all available values"/>
                                        </StackPanel>

                                        <Border Grid.Row="2" Background="#FFFFCC" BorderBrush="#AAA" BorderThickness="0,1,0,0" Padding="0,2">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Width="360" Text="Total:" Foreground="#FF00FF" FontWeight="Bold" TextAlignment="Right" Padding="0,0,10,0" VerticalAlignment="Center" Margin="0,0,2,0"/>
                                                <ItemsControl ItemsSource="{Binding TotalCells}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Width="110" Margin="0,0,2,0" Text="{Binding DisplayValue}" TextAlignment="Center" FontWeight="Bold" Foreground="#FF00FF" VerticalAlignment="Center"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBlock Width="160" Margin="3,0,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Background="#FFD966" BorderBrush="#AAA" BorderThickness="1" Margin="0,0,0,5" Padding="0,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Width="360" Text="GRAND TOTAL:" Foreground="Black" FontWeight="Bold" TextAlignment="Right" Padding="0,0,10,0" VerticalAlignment="Center" Margin="0,0,5,0"/>

                        <ItemsControl ItemsSource="{Binding GrandTotalCells}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Width="110" Margin="0,0,2,0" Text="{Binding DisplayValue}" TextAlignment="Center" FontWeight="Bold" Foreground="Red" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="1" Margin="0,5,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="+ ADD CATEGORY TABLE" Style="{StaticResource SecondaryButton}" Width="150" Height="26" Command="{Binding AddCategoryTableCommand}"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="15,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Profile:" FontWeight="Bold" Foreground="#555" VerticalAlignment="Center" Margin="0,0,5,0"/>

                <ComboBox Width="180" Height="24" ItemsSource="{Binding SavedProfiles}" SelectedItem="{Binding SelectedProfileName}" Margin="0,0,5,0" ToolTip="Select a saved profile to load"/>

                <Button Content="Import..." Style="{StaticResource SecondaryButton}" Width="70" Height="24" Margin="0,0,5,0" Command="{Binding ImportProfileCommand}" ToolTip="Import a profile from a .txt file"/>

                <Button Content="Save" Style="{StaticResource SecondaryButton}" Width="60" Height="24" Margin="0,0,5,0" Command="{Binding SaveProfileCommand}" ToolTip="Save current settings to the selected profile"/>

                <Button Content="Save As..." Style="{StaticResource SecondaryButton}" Width="75" Height="24" Margin="0,0,5,0" Command="{Binding SaveAsProfileCommand}" ToolTip="Save current settings as a new profile (.txt)"/>

                <Button Content="Delete" Style="{StaticResource SecondaryButton}" Width="60" Height="24" Command="{Binding DeleteProfileCommand}" Foreground="Red" BorderBrush="#FFCCCC" Background="#FFF5F5" ToolTip="Delete the selected profile"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Close" Style="{StaticResource SecondaryButton}" Width="70" Height="26" Margin="0,0,8,0" IsCancel="True"/>
                <Button Content="EXPORT TO EXCEL" Style="{StaticResource PrimaryButton}" Width="130" Height="26" Command="{Binding ExportCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>