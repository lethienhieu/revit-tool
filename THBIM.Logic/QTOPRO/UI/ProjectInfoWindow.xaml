<Window x:Class="THBIM.ProjectInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Project Information" Height="250" Width="350"
        WindowStartupLocation="CenterScreen" Background="#FFF9F7F0" FontFamily="Segoe UI" FontSize="12">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="PROJECT INFORMATION" FontWeight="Bold" FontSize="14" Foreground="#C68C3E" Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <DockPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Project Name:" Width="90" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBox x:Name="txtProjectName" Height="24" Padding="3,0" VerticalContentAlignment="Center"/>
        </DockPanel>

        <DockPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Measured by:" Width="90" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBox x:Name="txtMeasuredBy" Height="24" Padding="3,0" VerticalContentAlignment="Center"/>
        </DockPanel>

        <DockPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Revision:" Width="90" VerticalAlignment="Center" FontWeight="Bold"/>
            <TextBox x:Name="txtRevision" Height="24" Padding="3,0" VerticalContentAlignment="Center" Text="0"/>
        </DockPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="70" Height="26" Margin="0,0,10,0" Background="White" BorderBrush="#CCC" Click="BtnCancel_Click"/>
            <Button Content="OK &amp; Save" Width="90" Height="26" Background="#D9A566" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnOK_Click"/>
        </StackPanel>
    </Grid>
</Window>