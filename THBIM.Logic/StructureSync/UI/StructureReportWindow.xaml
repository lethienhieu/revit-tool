<Window x:Class="THBIM.Views.StructureReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Analysis Report" Height="700" Width="1000"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="#D9A566"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#FFF9F7F0"/>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFF9F7F0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="10" BorderBrush="{StaticResource Primary}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource Primary}" CornerRadius="9,9,0,0" MouseDown="Header_MouseDown">
                <Grid>
                    <TextBlock Text="Smart Tracking Report - Pro Max" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" Margin="15,0,0,0"/>
                    <Button Content="✕" Click="BtnClose_Click" HorizontalAlignment="Right" Width="40" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="16"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="10">
                <DataGrid x:Name="DgReport" AutoGenerateColumns="False" CanUserAddRows="False"
                          IsReadOnly="True" Background="White" BorderThickness="0"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEE"
                          SelectionMode="Extended" SelectionChanged="DgReport_SelectionChanged"
                          PreviewKeyDown="DgReport_PreviewKeyDown" >
                    <DataGrid.Resources>
                        <Style TargetType="DataGridCell">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#D5F5E3"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#D5F5E3"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Status" Width="70" SortMemberPath="Severity" CanUserSort="True" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Ellipse Width="12" Height="12" Fill="{Binding SeverityColor}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Set" Binding="{Binding SetName}" Width="80"/>
                        <DataGridTextColumn Header="Issue Type" Binding="{Binding StatusDisplay}" FontWeight="SemiBold" Width="120"/>

                        <DataGridTextColumn Header="Diagnosis" Binding="{Binding Diagnosis}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                    <Setter Property="Padding" Value="5"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Tech Data" Binding="{Binding TechData}" Width="270" Foreground="#777"/>

                        <DataGridTemplateColumn Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Sync" FontSize="11" Padding="5,2" Click="BtnSyncPair_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#2ECC71"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusDisplay}" Value="Synced">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                        <Setter Property="Background" Value="#CCC"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="3"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Edit pair only when parent/child is missing -->
                        <DataGridTemplateColumn Width="65">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Edit" FontSize="11" Padding="5,2" Click="BtnEditPair_Click">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="#F1C40F"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusDisplay}" Value="Missing Parent">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusDisplay}" Value="Missing Child">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Delete (supports multi-selection via code-behind) -->
                        <DataGridTemplateColumn Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="X"
                                            Width="24" Height="24"
                                            Background="#E74C3C"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Click="BtnRemovePair_Click"
                                            Padding="0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Grid Grid.Row="2" Margin="10,0,10,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="Select a row to highlight in model" VerticalAlignment="Center" Foreground="#999" FontStyle="Italic" Margin="0,0,15,0"/>
                    <Button Content="Close" Width="100" Height="30" Background="{StaticResource Primary}" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="BtnClose_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>

                    <Button x:Name="BtnAddPair"
                            Content="Add"
                            Width="100"
                            Height="30"
                            Margin="10,0,0,0"
                            Background="{StaticResource Primary}"
                            Foreground="White"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="BtnAddPair_Click"
                            Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
