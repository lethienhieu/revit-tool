<Window x:Class="THBIM.CombineOrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sheet Order" Height="450" Width="650" 
        WindowStartupLocation="CenterScreen" Background="#F4F4F4" FontFamily="Segoe UI">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid x:Name="DgOrder" Grid.Row="0" AutoGenerateColumns="False" CanUserAddRows="False" 
                  SelectionMode="Single" SelectionUnit="FullRow" HeadersVisibility="Column"
                  GridLinesVisibility="All" HorizontalGridLinesBrush="#EEE" VerticalGridLinesBrush="#EEE"
                  RowHeight="30" Background="White" BorderBrush="#CCC" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Sheet Number" Binding="{Binding SheetNumber}" Width="180" IsReadOnly="True"/>
                <DataGridTextColumn Header="Sheet / View Name" Binding="{Binding SheetName}" Width="*" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,15">
            <Button Content="⏭" Width="35" Height="30" Margin="2,0" ToolTip="Move to Top" Click="BtnTop_Click" Background="White" BorderBrush="#CCC">
                <Button.LayoutTransform>
                    <RotateTransform Angle="-90"/>
                </Button.LayoutTransform>
            </Button>
            <Button Content="▲" Width="35" Height="30" Margin="2,0" ToolTip="Move Up" Click="BtnUp_Click" Background="White" BorderBrush="#CCC"/>
            <Button Content="▼" Width="35" Height="30" Margin="2,0" ToolTip="Move Down" Click="BtnDown_Click" Background="White" BorderBrush="#CCC"/>
            <Button Content="⏭" Width="35" Height="30" Margin="2,0" ToolTip="Move to Bottom" Click="BtnBottom_Click" Background="White" BorderBrush="#CCC">
                <Button.LayoutTransform>
                    <RotateTransform Angle="90"/>
                </Button.LayoutTransform>
            </Button>
        </StackPanel>

        <Grid Grid.Row="2">
            <TextBlock x:Name="TxtTotal" Text="Total number of items 0" VerticalAlignment="Center" Foreground="#555"/>
            <Button Content="OK" Width="80" Height="30" HorizontalAlignment="Right" IsDefault="True" Background="#D6D6D6" BorderBrush="#AAA" BorderThickness="1" Cursor="Hand" Click="BtnOk_Click"/>
        </Grid>
    </Grid>
</Window>