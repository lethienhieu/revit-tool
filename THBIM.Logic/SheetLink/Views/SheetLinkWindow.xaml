<Window x:Class="THBIM.SheetLinkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:THBIM"
        mc:Ignorable="d"
        Title="SheetLink"
        Width="1100" Height="700"
        MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        Background="#F0F0F0"
        FontFamily="Segoe UI"
        FontSize="12">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/THBIM.Logic;component/SheetLink/Styles/SheetLinkStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

        <!-- ── Scrollbar ── -->
        <Style x:Key="SbThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#C0C0C0" CornerRadius="3" Margin="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Icon Button (title bar) ── -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width"  Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background"      Value="#3A3A3A"/>
            <Setter Property="BorderBrush"     Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#CCCCCC"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A4A4A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Window control button ── -->
        <Style x:Key="WinBtn" TargetType="Button">
            <Setter Property="Width"  Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#AAAAAA"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="2" Width="22" Height="22">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#555555"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Close button (red hover) ── -->
        <Style x:Key="WinCloseBtn" TargetType="Button" BasedOn="{StaticResource WinBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C42B1C"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Tab RadioButton ── -->
        <Style x:Key="TabBtn" TargetType="RadioButton">
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="Background"      Value="#D0D0D0"/>
            <Setter Property="BorderBrush"     Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="1,1,1,0"/>
            <Setter Property="Foreground"      Value="#555555"/>
            <Setter Property="FontSize"        Value="12.5"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin"          Value="0,0,2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4,4,0,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E8E8E8"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#FFFFFF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#D0D0D0"/>
                                <Setter Property="Foreground" Value="#1A1A1A"/>
                                <Setter Property="FontWeight" Value="Medium"/>
                                <Setter TargetName="Bd" Property="Height" Value="34"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#DCDCDC"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#C8C8C8"/>
                                <Setter Property="Foreground" Value="#9A9A9A"/>
                                <Setter Property="Opacity" Value="0.5"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Profile ComboBox ── -->
        <Style x:Key="ProfileCmb" TargetType="ComboBox">
            <Setter Property="Width"  Value="140"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background"  Value="#4A4A4A"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#666666"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding"     Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#1A1A1A"/>
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Padding" Value="4,2"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#FFF3CC"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1" CornerRadius="3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="18"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="1" Text="▾" FontSize="10"
                                                           Foreground="#CCCCCC"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="6,0,20,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                      SnapsToDevicePixels="True">
                                    <Border x:Name="DropDownBorder"
                                            Background="White"
                                            BorderBrush="#D0D0D0"
                                            BorderThickness="1"
                                            CornerRadius="0,0,3,3">
                                        <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleButton" Property="Background" Value="#FFF3CC"/>
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="#E8C45A"/>
                                <Setter TargetName="ContentSite" Property="TextBlock.Foreground" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#2A2A2A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        </ResourceDictionary>
    </Window.Resources>

    <!-- Outer border gives a subtle window edge -->
    <Border BorderBrush="#444444" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <!-- Title bar -->
                <RowDefinition Height="26"/>
                <!-- Progress bar -->
                <RowDefinition Height="38"/>
                <!-- Tab nav -->
                <RowDefinition Height="*"/>
                <!-- Content -->
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════
                 ROW 0 — TITLE BAR
            ══════════════════════════════════════════ -->
            <Border Grid.Row="0"
                    Background="#2B2B2B"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <!-- Logo + Update -->
                        <ColumnDefinition Width="*"/>
                        <!-- Title center -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Profile + controls -->
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="18" FontWeight="Bold">
                            <Run Foreground="White">TH</Run><Run Foreground="#E8830A">BIM</Run>
                        </TextBlock>
                        <!-- Update button -->
                    </StackPanel>

                    <!-- Title -->
                    <TextBlock Grid.Column="1"
                               Text="SheetLink"
                               Foreground="#CCCCCC" FontSize="13"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <!-- Right: Profile + window controls -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <!-- Profile label -->
                        <TextBlock Text="👤 Profile"
                                   Foreground="#AAAAAA" FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>

                        <!-- Profile dropdown -->
                        <ComboBox x:Name="CbProfile"
                                  Style="{StaticResource ProfileCmb}"
                                  Margin="0,0,4,0"
                                  SelectionChanged="CbProfile_SelectionChanged"/>

                        <!-- Import Profile -->
                        <Button Content="📥"
                                Style="{StaticResource IconBtn}"
                                Margin="0,0,3,0"
                                ToolTip="Import Profile"
                                Click="BtnImportProfile_Click"/>

                        <!-- Save Profile -->
                        <Button Content="💾"
                                Style="{StaticResource IconBtn}"
                                Margin="0,0,3,0"
                                ToolTip="Save Profile"
                                Click="BtnSaveProfile_Click"/>

                        <!-- Delete Profile -->
                        <Button Content="🗑"
                                Style="{StaticResource IconBtn}"
                                Margin="0,0,6,0"
                                ToolTip="Delete Profile"
                                Click="BtnDeleteProfile_Click"/>

                        <!-- Separator -->
                        <Border Width="1" Height="18" Background="#444444" Margin="0,0,6,0"/>

                        <!-- Account -->
                        <Button Content="👤"
                                Style="{StaticResource IconBtn}"
                                Margin="0,0,3,0"
                                ToolTip="Account"
                                Click="BtnAccount_Click"/>

                        <!-- Help -->
                        <Button Content="?"
                                Style="{StaticResource IconBtn}"
                                Margin="0,0,6,0"
                                ToolTip="Help / Documentation"
                                FontWeight="Bold"
                                Click="BtnHelp_Click"/>

                        <!-- Separator -->
                        <Border Width="1" Height="18" Background="#444444" Margin="0,0,6,0"/>

                        <!-- Minimize -->
                        <Button Content="─"
                                Style="{StaticResource WinBtn}"
                                Margin="0,0,2,0"
                                Click="BtnMinimize_Click"/>

                        <!-- Maximize / Restore -->
                        <Button x:Name="BtnMaxRestore"
                                Content="□"
                                Style="{StaticResource WinBtn}"
                                Margin="0,0,2,0"
                                Click="BtnMaximize_Click"/>

                        <!-- Close -->
                        <Button Content="✕"
                                Style="{StaticResource WinCloseBtn}"
                                Click="BtnClose_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════
                 ROW 1 — PROGRESS BAR
            ══════════════════════════════════════════ -->
            <Border Grid.Row="1"
                    Background="#E8E8E8"
                    BorderBrush="#D0D0D0"
                    BorderThickness="0,0,0,1">
                <Grid Margin="10,3">
                    <Border x:Name="ProgressFill"
                            Background="#D8F0D8"
                            CornerRadius="3"
                            Height="20"
                            HorizontalAlignment="Stretch">
                        <TextBlock x:Name="TbProgress"
                                   Text="Completed   0%"
                                   Foreground="#2A6E2A"
                                   FontSize="12" FontWeight="Medium"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="10,0"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════
                 ROW 2 — TAB NAVIGATION
            ══════════════════════════════════════════ -->
            <Border Grid.Row="2"
                    Background="#E0E0E0"
                    BorderBrush="#D0D0D0"
                    BorderThickness="0,0,0,2">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Bottom"
                            Margin="8,0,0,0">

                    <!-- Model Categories -->
                    <RadioButton x:Name="TabModel"
                                 GroupName="MainTabs"
                                 IsChecked="True"
                                 Style="{StaticResource TabBtn}"
                                 Click="Tab_Click" Tag="Model"
                                 Content="Model Categories"/>

                    <!-- Annotation Categories -->
                    <RadioButton x:Name="TabAnnotation"
                                 GroupName="MainTabs"
                                 Style="{StaticResource TabBtn}"
                                 Click="Tab_Click" Tag="Annotation"
                                 Content="Annotation Categories"/>

                    <!-- Elements -->
                    <RadioButton x:Name="TabElements"
                                 GroupName="MainTabs"
                                 Style="{StaticResource TabBtn}"
                                 Click="Tab_Click" Tag="Elements"
                                 Content="Elements"/>

                    <!-- Schedules -->
                    <RadioButton x:Name="TabSchedules"
                                 GroupName="MainTabs"
                                 Style="{StaticResource TabBtn}"
                                 Click="Tab_Click" Tag="Schedules"
                                 Content="Schedules"/>

                    <!-- Spatial -->
                    <RadioButton x:Name="TabSpatial"
                                 GroupName="MainTabs"
                                 Style="{StaticResource TabBtn}"
                                 Click="Tab_Click" Tag="Spatial"
                                 Content="Spatial"/>

                    <!-- Preview/Edit -->
                    <RadioButton x:Name="TabPreview"
                                 GroupName="MainTabs"
                                 Style="{StaticResource TabBtn}"
                                 Click="Tab_Click" Tag="Preview"
                                 Content="Preview/Edit"/>

                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════
                 ROW 3 — CONTENT PANELS
                 Each UserControl stacked; Visibility toggled by Tab_Click
            ══════════════════════════════════════════ -->
            <Grid Grid.Row="3" Background="#FFFFFF">

                <!-- Model Categories -->
                <local:ModelCategoriesView
                    x:Name="ViewModelCategories"
                    Visibility="Visible"/>

                <!-- Annotation Categories -->
                <local:AnnotationCategoriesView
                    x:Name="ViewAnnotation"
                    Visibility="Collapsed"/>

                <!-- Elements -->
                <local:ElementsView
                    x:Name="ViewElements"
                    Visibility="Collapsed"/>

                <!-- Schedules -->
                <local:SchedulesView
                    x:Name="ViewSchedules"
                    Visibility="Collapsed"/>

                <!-- Spatial -->
                <local:SpatialView
                    x:Name="ViewSpatial"
                    Visibility="Collapsed"/>

                <!-- Preview/Edit -->
                <local:PreviewEditView
                    x:Name="ViewPreview"
                    Visibility="Collapsed"/>

            </Grid>

        </Grid>
    </Border>

</Window>
