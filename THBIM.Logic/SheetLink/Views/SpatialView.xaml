<UserControl x:Class="THBIM.SpatialView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1100"
             Background="#FFFFFF"
             FontFamily="Segoe UI"
             FontSize="12">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/THBIM.Logic;component/SheetLink/Styles/SheetLinkStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

        <Style x:Key="SbThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#C0C0C0" CornerRadius="3" Margin="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SbBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SbThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SbViewer" TargetType="ScrollViewer">
            <Setter Property="CanContentScroll" Value="True"/>
            <Setter Property="PanningMode" Value="VerticalFirst"/>
        </Style>

        <Style x:Key="Cb" TargetType="CheckBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
        </Style>

        <Style x:Key="Sb" TargetType="TextBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="5,0,22,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="Ph" Text="Search" Foreground="#AAAAAA" FontSize="12"
                                           Visibility="Collapsed"
                                           Margin="6,0,22,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Right" Margin="0,0,5,0"
                                           VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="12" IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Ph" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#E8830A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Cmb" TargetType="ComboBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF3CC"/>
                    <Setter Property="BorderBrush" Value="#E8C45A"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="Background" Value="#FFF3CC"/>
                    <Setter Property="BorderBrush" Value="#E8C45A"/>
                </Trigger>
                <Trigger Property="IsDropDownOpen" Value="True">
                    <Setter Property="Background" Value="#FFE89C"/>
                    <Setter Property="BorderBrush" Value="#E8C45A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="Ab" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CCCCCC"/>
                            </Trigger>
                            <Trigger Property="IsPressed"   Value="True">
                                <Setter Property="Background" Value="#BBBBBB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Srt" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsPressed"   Value="True">
                                <Setter Property="Background" Value="#C0C0C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrevBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#FFF8E8"/>
            <Setter Property="BorderBrush" Value="#D4AA40"/>
            <Setter Property="Foreground" Value="#7A5500"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FDF0CC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#2A6E2A"/>
            <Setter Property="BorderBrush" Value="#1A5A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A5A1A"/>
                </Trigger>
                <Trigger Property="IsEnabled"   Value="False">
                    <Setter Property="Background" Value="#AACCAA"/>
                    <Setter Property="BorderBrush" Value="#99BB99"/>
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- List row hover -->
        <Style x:Key="Row" TargetType="Border">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F6FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <!-- Spatial type toolbar -->
            <RowDefinition Height="*"/>
            <!-- 3-column content -->
            <RowDefinition Height="36"/>
            <!-- Legend + sort row -->
            <RowDefinition Height="28"/>
            <!-- Status bar -->
            <RowDefinition Height="44"/>
            <!-- Action bar -->
        </Grid.RowDefinitions>

        <!--ROW 0: SPATIAL TYPE TOOLBAR -->
        <Border Grid.Row="0" Background="#F4F4F4" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
            <Grid Margin="10,0">

                <!-- Rooms / Spaces dropdown -->
                <ComboBox x:Name="CbSpatialType"
                          Width="110"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          Style="{StaticResource Cmb}"
                          SelectedIndex="0"
                          SelectionChanged="CbSpatialType_SelectionChanged">
                    <ComboBoxItem Content="Rooms"/>
                    <ComboBoxItem Content="Spaces"/>
                </ComboBox>

                <!-- Refresh button (right, orange) -->
                <Button HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Width="28" Height="28"
                        Background="#E8830A"
                        BorderThickness="0"
                        Foreground="White"
                        Cursor="Hand"
                        ToolTip="Refresh"
                        Click="BtnRefresh_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                <TextBlock Text="?" FontSize="15" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#D07508"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!--ROW 1: 3-COLUMN -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Select Rooms/Spaces -->
                <ColumnDefinition Width="1"/>
                <!-- divider -->
                <ColumnDefinition Width="*"/>
                <!-- Available Parameters (yellow) -->
                <ColumnDefinition Width="36"/>
                <!-- Arrow column -->
                <ColumnDefinition Width="*"/>
                <!-- Selected Parameters -->
            </Grid.ColumnDefinitions>

            <!-- ==============================
                 COL 0: SELECT ROOMS / SPACES
            ============================== -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <!-- Header -->
                    <RowDefinition Height="28"/>
                    <!-- Search -->
                    <RowDefinition Height="24"/>
                    <!-- Sub-column headers: Number | Name -->
                    <RowDefinition Height="*"/>
                    <!-- List -->
                    <RowDefinition Height="28"/>
                    <!-- Hide unchecked -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Padding="8,0">
                    <TextBlock x:Name="TbSelectHeader"
                               Text="Select Rooms"
                               FontSize="12" FontWeight="Medium"
                               Foreground="#555555" VerticalAlignment="Center"/>
                </Border>

                <!-- Search -->
                <TextBox Grid.Row="1" x:Name="TbSrchSpatial"
                         Style="{StaticResource Sb}"
                         Margin="6,2"
                         TextChanged="TbSrchSpatial_TextChanged"/>

                <!-- Sub-headers: checkbox | Number | divider | Name -->
                <Border Grid.Row="2"
                        Background="#F0F0F0"
                        BorderBrush="#D0D0D0"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <!-- checkbox -->
                            <ColumnDefinition Width="80"/>
                            <!-- Number -->
                            <ColumnDefinition Width="1"/>
                            <!-- divider -->
                            <ColumnDefinition Width="*"/>
                            <!-- Name -->
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  x:Name="ChkAllSpatial"
                                  Style="{StaticResource Cb}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Margin="0"
                                  Click="ChkAllSpatial_Click"/>

                        <TextBlock Grid.Column="1"
                                   Text="Number"
                                   FontSize="11.5" FontWeight="Medium"
                                   Foreground="#555555"
                                   VerticalAlignment="Center"
                                   Margin="4,0"/>

                        <Border Grid.Column="2" Background="#D0D0D0"/>

                        <TextBlock Grid.Column="3"
                                   Text="Name"
                                   FontSize="11.5" FontWeight="Medium"
                                   Foreground="#555555"
                                   VerticalAlignment="Center"
                                   Margin="8,0"/>
                    </Grid>
                </Border>

                <!-- Rooms / Spaces list -->
                <ScrollViewer Grid.Row="3"
                              Style="{StaticResource SbViewer}"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="SpSpatial">
                        <!-- Rows populated from code-behind.
                             Template per row: -->
                        <Border Style="{StaticResource Row}" Tag="101|Office A"         MouseLeftButtonDown="SpatialRow_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource Cb}" Margin="0" HorizontalAlignment="Center" Click="SpatialCheckBox_Click"/>
                                <TextBlock Grid.Column="1" Text="101" FontSize="12" Foreground="#555555" VerticalAlignment="Center" Margin="4,0"/>
                                <Border Grid.Column="2" Background="#E0E0E0"/>
                                <TextBlock Grid.Column="3" Text="Office A" FontSize="12" Foreground="#1A1A1A" VerticalAlignment="Center" Margin="8,0"/>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="102|Office B"         MouseLeftButtonDown="SpatialRow_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="17*"/>
                                    <ColumnDefinition Width="104*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Style="{StaticResource Cb}" HorizontalAlignment="Center" Click="SpatialCheckBox_Click"/>
                                <TextBlock Grid.Column="1" Text="102" FontSize="12" Foreground="#555555" VerticalAlignment="Center" Margin="4,0,4,0"/>
                                <Border Grid.Column="2" Background="#E0E0E0"/>
                                <TextBlock Grid.Column="3" Text="Office B" FontSize="12" Foreground="#1A1A1A" VerticalAlignment="Center" Margin="8,0,8,0" Grid.ColumnSpan="2"/>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="103|Conference Room"  MouseLeftButtonDown="SpatialRow_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource Cb}" Margin="0" HorizontalAlignment="Center" Click="SpatialCheckBox_Click"/>
                                <TextBlock Grid.Column="1" Text="103" FontSize="12" Foreground="#555555" VerticalAlignment="Center" Margin="4,0"/>
                                <Border Grid.Column="2" Background="#E0E0E0"/>
                                <TextBlock Grid.Column="3" Text="Conference Room" FontSize="12" Foreground="#1A1A1A" VerticalAlignment="Center" Margin="8,0"/>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="201|Open Space"       MouseLeftButtonDown="SpatialRow_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource Cb}" Margin="0" HorizontalAlignment="Center" Click="SpatialCheckBox_Click"/>
                                <TextBlock Grid.Column="1" Text="201" FontSize="12" Foreground="#555555" VerticalAlignment="Center" Margin="4,0"/>
                                <Border Grid.Column="2" Background="#E0E0E0"/>
                                <TextBlock Grid.Column="3" Text="Open Space" FontSize="12" Foreground="#1A1A1A" VerticalAlignment="Center" Margin="8,0"/>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="202|Break Room"       MouseLeftButtonDown="SpatialRow_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource Cb}" Margin="0" HorizontalAlignment="Center" Click="SpatialCheckBox_Click"/>
                                <TextBlock Grid.Column="1" Text="202" FontSize="12" Foreground="#555555" VerticalAlignment="Center" Margin="4,0"/>
                                <Border Grid.Column="2" Background="#E0E0E0"/>
                                <TextBlock Grid.Column="3" Text="Break Room" FontSize="12" Foreground="#1A1A1A" VerticalAlignment="Center" Margin="8,0"/>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="203|Storage"          MouseLeftButtonDown="SpatialRow_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource Cb}" Margin="0" HorizontalAlignment="Center" Click="SpatialCheckBox_Click"/>
                                <TextBlock Grid.Column="1" Text="203" FontSize="12" Foreground="#555555" VerticalAlignment="Center" Margin="4,0"/>
                                <Border Grid.Column="2" Background="#E0E0E0"/>
                                <TextBlock Grid.Column="3" Text="Storage" FontSize="12" Foreground="#1A1A1A" VerticalAlignment="Center" Margin="8,0"/>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="301|Lobby"            MouseLeftButtonDown="SpatialRow_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource Cb}" Margin="0" HorizontalAlignment="Center" Click="SpatialCheckBox_Click"/>
                                <TextBlock Grid.Column="1" Text="301" FontSize="12" Foreground="#555555" VerticalAlignment="Center" Margin="4,0"/>
                                <Border Grid.Column="2" Background="#E0E0E0"/>
                                <TextBlock Grid.Column="3" Text="Lobby" FontSize="12" Foreground="#1A1A1A" VerticalAlignment="Center" Margin="8,0"/>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="302|Corridor 01"      MouseLeftButtonDown="SpatialRow_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource Cb}" Margin="0" HorizontalAlignment="Center" Click="SpatialCheckBox_Click"/>
                                <TextBlock Grid.Column="1" Text="302" FontSize="12" Foreground="#555555" VerticalAlignment="Center" Margin="4,0"/>
                                <Border Grid.Column="2" Background="#E0E0E0"/>
                                <TextBlock Grid.Column="3" Text="Corridor 01" FontSize="12" Foreground="#1A1A1A" VerticalAlignment="Center" Margin="8,0"/>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="303|WC Male"          MouseLeftButtonDown="SpatialRow_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource Cb}" Margin="0" HorizontalAlignment="Center" Click="SpatialCheckBox_Click"/>
                                <TextBlock Grid.Column="1" Text="303" FontSize="12" Foreground="#555555" VerticalAlignment="Center" Margin="4,0"/>
                                <Border Grid.Column="2" Background="#E0E0E0"/>
                                <TextBlock Grid.Column="3" Text="WC Male" FontSize="12" Foreground="#1A1A1A" VerticalAlignment="Center" Margin="8,0"/>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="304|WC Female"        MouseLeftButtonDown="SpatialRow_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource Cb}" Margin="0" HorizontalAlignment="Center" Click="SpatialCheckBox_Click"/>
                                <TextBlock Grid.Column="1" Text="304" FontSize="12" Foreground="#555555" VerticalAlignment="Center" Margin="4,0"/>
                                <Border Grid.Column="2" Background="#E0E0E0"/>
                                <TextBlock Grid.Column="3" Text="WC Female" FontSize="12" Foreground="#1A1A1A" VerticalAlignment="Center" Margin="8,0"/>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="305|Server Room"      MouseLeftButtonDown="SpatialRow_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Style="{StaticResource Cb}" Margin="0" HorizontalAlignment="Center" Click="SpatialCheckBox_Click"/>
                                <TextBlock Grid.Column="1" Text="305" FontSize="12" Foreground="#555555" VerticalAlignment="Center" Margin="4,0"/>
                                <Border Grid.Column="2" Background="#E0E0E0"/>
                                <TextBlock Grid.Column="3" Text="Server Room" FontSize="12" Foreground="#1A1A1A" VerticalAlignment="Center" Margin="8,0"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Hide unchecked -->
                <Border Grid.Row="4" Background="#FAFAFA" BorderBrush="#E8E8E8" BorderThickness="0,1,0,0" Padding="8,0">
                    <CheckBox x:Name="ChkHide" Content="Hide un-checked elements"
                              Style="{StaticResource Cb}" Click="ChkHide_Click"/>
                </Border>
            </Grid>

            <!-- VERTICAL DIVIDER -->
            <Border Grid.Column="1" Background="#D0D0D0"/>

            <!-- ==============================
                 COL 2: AVAILABLE PARAMETERS
                 � header & dropdown are YELLOW
                 � no Type params (Instance + Read-only only)
            ============================== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header � yellow tint -->
                <Border Grid.Row="0"
                        Background="#FDF0CC"
                        BorderBrush="#E8C45A"
                        BorderThickness="0,0,0,1"
                        Padding="8,0">
                    <TextBlock Text="Available Parameters"
                               FontSize="12" FontWeight="Medium"
                               Foreground="#8A6010"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Filter � yellow tinted -->
                <ComboBox Grid.Row="1" x:Name="CbParamFilter" Style="{StaticResource Cmb}" Margin="6,2" IsEditable="True" IsReadOnly="True" Text="Instance, Read-only" Background="#FDF0CC">
                    <CheckBox x:Name="ChkAvailInstance" Content="Instance" IsChecked="True" Style="{StaticResource Cb}" Margin="4,2" Click="ParamFilter_CheckedChanged"/>
                    <CheckBox x:Name="ChkAvailReadOnly" Content="Read-only" IsChecked="True" Style="{StaticResource Cb}" Margin="4,2" Click="ParamFilter_CheckedChanged"/>
                </ComboBox>

                <TextBox Grid.Row="2" x:Name="TbSrchAvail"
                         Style="{StaticResource Sb}" Margin="6,2"
                         TextChanged="TbSrchAvail_TextChanged"/>

                <ScrollViewer Grid.Row="3" Style="{StaticResource SbViewer}" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="SpAvail"/>
                </ScrollViewer>
            </Grid>

            <!-- COL 3: ARROWS -->
            <Border Grid.Column="3" Background="#F4F4F4" BorderBrush="#D0D0D0" BorderThickness="1,0">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Button Content="?" Style="{StaticResource Ab}" Margin="0,0,0,6" ToolTip="Add"    Click="BtnRight_Click"/>
                    <Button Content="?" Style="{StaticResource Ab}"                   ToolTip="Remove" Click="BtnLeft_Click"/>
                </StackPanel>
            </Border>

            <!-- ==============================
                 COL 4: SELECTED PARAMETERS
            ============================== -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Padding="8,0">
                    <TextBlock Text="Selected Parameters"
                               FontSize="12" FontWeight="Medium"
                               Foreground="#555555" VerticalAlignment="Center"/>
                </Border>

                <ComboBox Grid.Row="1" x:Name="CbSelParamFilter" Style="{StaticResource Cmb}" Margin="6,2" IsEditable="True" IsReadOnly="True" Text="Instance, Read-only">
                    <CheckBox x:Name="ChkSelInstance" Content="Instance" IsChecked="True" Style="{StaticResource Cb}" Margin="4,2" Click="SelParamFilter_CheckedChanged"/>
                    <CheckBox x:Name="ChkSelReadOnly" Content="Read-only" IsChecked="True" Style="{StaticResource Cb}" Margin="4,2" Click="SelParamFilter_CheckedChanged"/>
                </ComboBox>

                <TextBox Grid.Row="2" x:Name="TbSrchSel"
                         Style="{StaticResource Sb}" Margin="6,2"
                         TextChanged="TbSrchSel_TextChanged"/>

                <ScrollViewer Grid.Row="3" Style="{StaticResource SbViewer}" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="SpSel"/>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!--ROW 2: LEGEND + SORT -->
        <Border Grid.Row="2" Background="#F4F4F4" BorderBrush="#D0D0D0" BorderThickness="0,1,0,0">
            <Grid Margin="8,0">

                <!-- Left: Include Linked Files (no Export by Type ID for Spatial) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox x:Name="ChkLinked" Content="Include Linked Files"
                              Style="{StaticResource Cb}"/>
                </StackPanel>

                <!-- Right: Instance + Read-only badges (no Type badge) + sort -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">

                    <Border Style="{StaticResource InstanceBadgeStyle}" Margin="0,0,4,0" MouseLeftButtonDown="BadgeInst_Click">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="8" Height="8" Fill="#4A7C2F" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Instance" FontSize="11.5" FontWeight="Medium" Foreground="#4A7C2F"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ReadOnlyBadgeStyle}" Margin="0,0,8,0" MouseLeftButtonDown="BadgeRo_Click">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle Width="8" Height="8" Fill="#922222" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Read-only" FontSize="11.5" FontWeight="Medium" Foreground="#922222"/>
                        </StackPanel>
                    </Border>

                    <Button Content="⏫" Style="{StaticResource Srt}" Margin="0,0,2,0" ToolTip="Move to top"    Click="SrtTop_Click"/>
                    <Button Content="🔼" Style="{StaticResource Srt}" Margin="0,0,2,0" ToolTip="Move up"        Click="SrtUp_Click"/>
                    <Button Content="🔽" Style="{StaticResource Srt}" Margin="0,0,2,0" ToolTip="Move down"      Click="SrtDown_Click"/>
                    <Button Content="⏬" Style="{StaticResource Srt}" Margin="0,0,2,0" ToolTip="Move to bottom" Click="SrtBot_Click"/>
                    <Button Content="↺"  Style="{StaticResource Srt}" FontSize="13"    ToolTip="Reset sort"     Click="SrtReset_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!--ROW 3: STATUS BAR -->
        <Border Grid.Row="3" Background="#E8E8E8" BorderBrush="#D0D0D0" BorderThickness="0,1,0,0" Padding="10,0">
            <TextBlock x:Name="TbStatus"
                       Text="Total number of selected rooms 0 | parameters found 0 | parameters selected 0"
                       FontSize="11.5" Foreground="#555555" VerticalAlignment="Center"/>
        </Border>

        <!--ROW 4: ACTION BAR -->
        <Border Grid.Row="4" Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="0,1,0,0" Padding="10,0">
            <Grid VerticalAlignment="Center">
                <!-- Actions right -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">

                    <Button Content="Reset Values" Style="{StaticResource Btn}"     Margin="0,0,6,0" Click="BtnReset_Click"/>
                    <Button x:Name="BtnPreview" Content="Preview/Edit" Style="{StaticResource PrevBtn}" Margin="0,0,6,0" Click="BtnPreview_Click"/>

                                        <ComboBox x:Name="CbImportAction" Style="{StaticResource Cmb}" Height="30" Width="170" Margin="0,0,6,0"
                              SelectionChanged="CbImportAction_SelectionChanged">
                        <ComboBoxItem Content="Import" IsSelected="True"/>
                        <ComboBoxItem Content="Import from Excel..."/>
                    </ComboBox>

                    <!-- Export Template (Spatial-specific, replaces Export) -->
                    <Button Content="Export Template"
                            Style="{StaticResource GBtn}"
                            Click="BtnExportTemplate_Click"/>

                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>

