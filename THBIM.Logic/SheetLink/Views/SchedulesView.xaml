<UserControl x:Class="THBIM.SchedulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1100"
             Background="#FFFFFF"
             FontFamily="Segoe UI"
             FontSize="12">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/THBIM.Logic;component/SheetLink/Styles/SheetLinkStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

        <Style x:Key="SbThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#C0C0C0" CornerRadius="3" Margin="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SbBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SbThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SbViewer" TargetType="ScrollViewer">
            <Setter Property="CanContentScroll" Value="True"/>
            <Setter Property="PanningMode" Value="VerticalFirst"/>
        </Style>

        <Style x:Key="Cb" TargetType="CheckBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
        </Style>

        <Style x:Key="Rb" TargetType="RadioButton">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
        </Style>

        <Style x:Key="Sb" TargetType="TextBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="5,0,22,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="Ph" Text="Search" Foreground="#AAAAAA" FontSize="12"
                                           Visibility="Collapsed"
                                           Margin="6,0,22,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Right" Margin="0,0,5,0"
                                           VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="12" IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Ph" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#E8830A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Cmb" TargetType="ComboBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF3CC"/>
                    <Setter Property="BorderBrush" Value="#E8C45A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="Tb" TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DDDDDD"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"   Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsPressed"   Value="True">
                                <Setter Property="Background" Value="#C0C0C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrevBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#FFF8E8"/>
            <Setter Property="BorderBrush" Value="#D4AA40"/>
            <Setter Property="Foreground" Value="#7A5500"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FDF0CC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#2A6E2A"/>
            <Setter Property="BorderBrush" Value="#1A5A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A5A1A"/>
                </Trigger>
                <Trigger Property="IsEnabled"   Value="False">
                    <Setter Property="Background" Value="#AACCAA"/>
                    <Setter Property="BorderBrush" Value="#99BB99"/>
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="Row" TargetType="Border">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F6FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RowSelected" TargetType="Border" BasedOn="{StaticResource Row}">
            <Setter Property="Background" Value="#DDEEFF"/>
        </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- 2-column content -->
            <RowDefinition Height="28"/>
            <!-- Bottom checkboxes -->
            <RowDefinition Height="28"/>
            <!-- Status bar -->
            <RowDefinition Height="44"/>
            <!-- Action bar -->
        </Grid.RowDefinitions>

        <!--ROW 0: TOOLBAR -->
        <Border Grid.Row="0" Background="#F4F4F4" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
            <Grid Margin="10,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton Content="Whole Model" GroupName="ScopeSched"
                                 IsChecked="True" Style="{StaticResource Rb}"/>
                    <RadioButton Content="Active View" GroupName="ScopeSched"
                                 Style="{StaticResource Rb}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- 3D Section Box -->
                    <Button Width="28" Height="28" Style="{StaticResource Tb}" Padding="0"
                            ToolTip="3D Section Box" Margin="0,0,6,0" Click="BtnSectionBox_Click">
                        <TextBlock Text="⬡" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button Content="Isolate Selection"        Style="{StaticResource Tb}" IsEnabled="False" Margin="0,0,6,0"/>
                    <Button Content="Export Project Standards" Style="{StaticResource Tb}" Click="BtnExportProjectStandards_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!--ROW 1: 2-COLUMN LAYOUT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Select Schedules -->
                <ColumnDefinition Width="1"/>
                <!-- divider -->
                <ColumnDefinition Width="*"/>
                <!-- Parameters -->
            </Grid.ColumnDefinitions>

            <!-- ==============================
                 COL 0: SELECT SCHEDULES
            ============================== -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Padding="8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="ChkAllSchedules" Style="{StaticResource Cb}" Click="ChkAllSchedules_Click"/>
                        <TextBlock Text="Select Schedules" FontSize="12" FontWeight="Medium"
                                   Foreground="#555555" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Schedule type filter -->
                <ComboBox Grid.Row="1" x:Name="CbSchedType"
                          Style="{StaticResource Cmb}" Margin="6,2" SelectedIndex="0"
                          SelectionChanged="CbSchedType_SelectionChanged">
                    <ComboBoxItem Content="all"/>
                    <ComboBoxItem Content="Key Schedules"/>
                    <ComboBoxItem Content="Material Takeoff"/>
                    <ComboBoxItem Content="Multi-Category"/>
                    <ComboBoxItem Content="Panel Schedule"/>
                    <ComboBoxItem Content="Sheet List"/>
                    <ComboBoxItem Content="View List"/>
                </ComboBox>

                <!-- Search -->
                <TextBox Grid.Row="2" x:Name="TbSrchSched"
                         Style="{StaticResource Sb}" Margin="6,2"
                         TextChanged="TbSrchSched_TextChanged"/>

                <!-- Schedule list -->
                <ScrollViewer Grid.Row="3" Style="{StaticResource SbViewer}"
                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="SpSchedules">
                        <Border Style="{StaticResource Row}" Tag="Door Schedule"                          MouseLeftButtonDown="Schedule_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Style="{StaticResource Cb}" Click="ScheduleCheckBox_Click" Tag="Door Schedule"/>
                                <TextBlock Text="Door Schedule" FontSize="12.5" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="Electrical Analytical Bus Schedule"     MouseLeftButtonDown="Schedule_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Style="{StaticResource Cb}" Click="ScheduleCheckBox_Click" Tag="Electrical Analytical Bus Schedule"/>
                                <TextBlock Text="Electrical Analytical Bus Schedule" FontSize="12.5" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="Electrical Analytical Load Schedule"    MouseLeftButtonDown="Schedule_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Style="{StaticResource Cb}" Click="ScheduleCheckBox_Click" Tag="Electrical Analytical Load Schedule"/>
                                <TextBlock Text="Electrical Analytical Load Schedule" FontSize="12.5" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="Level Schedule"                         MouseLeftButtonDown="Schedule_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Style="{StaticResource Cb}" Click="ScheduleCheckBox_Click" Tag="Level Schedule"/>
                                <TextBlock Text="Level Schedule" FontSize="12.5" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="Room Finish Schedule"                   MouseLeftButtonDown="Schedule_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Style="{StaticResource Cb}" Click="ScheduleCheckBox_Click" Tag="Room Finish Schedule"/>
                                <TextBlock Text="Room Finish Schedule" FontSize="12.5" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="Sheet Index"                            MouseLeftButtonDown="Schedule_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Style="{StaticResource Cb}" Click="ScheduleCheckBox_Click" Tag="Sheet Index"/>
                                <TextBlock Text="Sheet Index" FontSize="12.5" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="Space Outdoor Air Schedule"             MouseLeftButtonDown="Schedule_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Style="{StaticResource Cb}" Click="ScheduleCheckBox_Click" Tag="Space Outdoor Air Schedule"/>
                                <TextBlock Text="Space Outdoor Air Schedule" FontSize="12.5" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="Structural Column Schedule"             MouseLeftButtonDown="Schedule_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Style="{StaticResource Cb}" Click="ScheduleCheckBox_Click" Tag="Structural Column Schedule"/>
                                <TextBlock Text="Structural Column Schedule" FontSize="12.5" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="Structural Foundation Schedule"         MouseLeftButtonDown="Schedule_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Style="{StaticResource Cb}" Click="ScheduleCheckBox_Click" Tag="Structural Foundation Schedule"/>
                                <TextBlock Text="Structural Foundation Schedule" FontSize="12.5" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="Structural Framing Schedule"            MouseLeftButtonDown="Schedule_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Style="{StaticResource Cb}" Click="ScheduleCheckBox_Click" Tag="Structural Framing Schedule"/>
                                <TextBlock Text="Structural Framing Schedule" FontSize="12.5" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="Structural Wall Schedule"               MouseLeftButtonDown="Schedule_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Style="{StaticResource Cb}" Click="ScheduleCheckBox_Click" Tag="Structural Wall Schedule"/>
                                <TextBlock Text="Structural Wall Schedule" FontSize="12.5" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="Window Schedule"                        MouseLeftButtonDown="Schedule_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Style="{StaticResource Cb}" Click="ScheduleCheckBox_Click" Tag="Window Schedule"/>
                                <TextBlock Text="Window Schedule" FontSize="12.5" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="Working_Sheet List"                     MouseLeftButtonDown="Schedule_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Style="{StaticResource Cb}" Click="ScheduleCheckBox_Click" Tag="Working_Sheet List"/>
                                <TextBlock Text="Working_Sheet List" FontSize="12.5" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource Row}" Tag="Working_View List"                      MouseLeftButtonDown="Schedule_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <CheckBox Style="{StaticResource Cb}" Click="ScheduleCheckBox_Click" Tag="Working_View List"/>
                                <TextBlock Text="Working_View List" FontSize="12.5" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- VERTICAL DIVIDER -->
            <Border Grid.Column="1" Background="#D0D0D0"/>

            <!-- ==============================
                 COL 2: PARAMETERS
                 (single column, no arrows needed)
            ============================== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="36"/>
                    <!-- Legend badges at bottom -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Padding="8,0">
                    <TextBlock Text="Parameters" FontSize="12" FontWeight="Medium"
                               Foreground="#555555" VerticalAlignment="Center"/>
                </Border>

                <!-- Filter -->
                <ComboBox Grid.Row="1" x:Name="CbParamFilter" Style="{StaticResource Cmb}" Margin="6,2" IsEditable="True" IsReadOnly="True" Text="Instance, Type, Read-only">
                    <CheckBox x:Name="ChkParamInst" Content="Instance" IsChecked="True" Style="{StaticResource Cb}" Margin="4,2" Click="ParamFilter_CheckedChanged"/>
                    <CheckBox x:Name="ChkParamType" Content="Type" IsChecked="True" Style="{StaticResource Cb}" Margin="4,2" Click="ParamFilter_CheckedChanged"/>
                    <CheckBox x:Name="ChkParamRo" Content="Read-only" IsChecked="True" Style="{StaticResource Cb}" Margin="4,2" Click="ParamFilter_CheckedChanged"/>
                </ComboBox>

                <!-- Search -->
                <TextBox Grid.Row="2" x:Name="TbSrchParam"
                         Style="{StaticResource Sb}" Margin="6,2"
                         TextChanged="TbSrchParam_TextChanged"/>

                <!-- Parameters list � populated when schedule is clicked -->
                <ScrollViewer Grid.Row="3" Style="{StaticResource SbViewer}"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="SpParams"/>
                </ScrollViewer>

                <!-- Legend badges fixed at bottom of params column -->
                <Border Grid.Row="4"
                        Background="#F4F4F4"
                        BorderBrush="#D0D0D0"
                        BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="6,0">
                        <Border Style="{StaticResource InstanceBadgeStyle}" Margin="0,0,4,0" MouseLeftButtonDown="BadgeInst_Click">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="8" Height="8" Fill="#4A7C2F" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="Instance" FontSize="11.5" FontWeight="Medium" Foreground="#4A7C2F"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource TypeBadgeStyle}" Margin="0,0,4,0" MouseLeftButtonDown="BadgeType_Click">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="8" Height="8" Fill="#8A6010" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="Type" FontSize="11.5" FontWeight="Medium" Foreground="#8A6010"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource ReadOnlyBadgeStyle}" Margin="0,0,0,0" MouseLeftButtonDown="BadgeRo_Click">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="8" Height="8" Fill="#922222" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="Read-only" FontSize="11.5" FontWeight="Medium" Foreground="#922222"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!--ROW 2: BOTTOM CHECKBOXES -->
        <Border Grid.Row="2" Background="#F4F4F4" BorderBrush="#D0D0D0" BorderThickness="0,1,0,0" Padding="8,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <CheckBox x:Name="ChkHideUnchecked" Content="Hide un-checked schedules"
                          Style="{StaticResource Cb}" Margin="0,0,14,0"
                          Click="ChkHideUnchecked_Click"/>
                <CheckBox x:Name="ChkExportByTypeId" Content="Export by Type ID"
                          Style="{StaticResource Cb}"/>
            </StackPanel>
        </Border>

        <!--ROW 3: STATUS BAR -->
        <Border Grid.Row="3" Background="#E8E8E8" BorderBrush="#D0D0D0" BorderThickness="0,1,0,0" Padding="10,0">
            <TextBlock x:Name="TbStatus"
                       Text="Total number of selected schedules 0 | parameters found 0"
                       FontSize="11.5" Foreground="#555555" VerticalAlignment="Center"/>
        </Border>

        <!--ROW 4: ACTION BAR -->
        <Border Grid.Row="4" Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="0,1,0,0" Padding="10,0">
            <Grid VerticalAlignment="Center">
                <!-- Actions right -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">

                    <Button Content="Reset Values" Style="{StaticResource Btn}"     Margin="0,0,6,0" Click="BtnReset_Click"/>
                    <Button x:Name="BtnPreview" Content="Preview/Edit" Style="{StaticResource PrevBtn}" Margin="0,0,6,0" Click="BtnPreview_Click"/>

                                        <ComboBox x:Name="CbImportAction" Style="{StaticResource Cmb}" Height="30" Width="170" Margin="0,0,6,0"
                              SelectionChanged="CbImportAction_SelectionChanged">
                        <ComboBoxItem Content="Import" IsSelected="True"/>
                        <ComboBoxItem Content="Import from Excel..."/>
                    </ComboBox>

                    <!-- Export -->
                    <Button x:Name="BtnExport" Content="Export"
                            Style="{StaticResource GBtn}"
                            IsEnabled="False"
                            Click="BtnExport_Click"/>

                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>

