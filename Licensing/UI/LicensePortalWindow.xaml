<Window x:Class="THBIM.Tools.LicensePortalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="THBIM Licensing" Height="600" Width="720"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        FontFamily="Segoe UI" Background="#FFF9F7F0">

    <Window.Resources>
        <!-- Palette -->
        <SolidColorBrush x:Key="Primary"     Color="#D9A566"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#C68C3E"/>
        <!-- White → gold gradient (stronger gold) -->

        <!-- Auto style when text = PERMANENT -->
        <Style x:Key="ExpireTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode"  Value="ClearType"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="PERMANENT">
                    <!-- strong gold text -->
                    <Setter Property="Foreground" Value="#FFFF99"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <!-- light gray background + padding -->
                    <Setter Property="Background" Value="#555555"/>
                    <Setter Property="Padding" Value="6,2"/>
                    <!-- subtle shadow -->
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="0" Opacity="0.9"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Buttons -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Background" Value="#FFF5EFE1"/>
            <Setter Property="Foreground" Value="#7A5A2A"/>
            <Setter Property="BorderBrush" Value="#E7D1AC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Underlined TextBox -->
        <Style x:Key="UnderlinedTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0,0,0,1"/>
                            <Border VerticalAlignment="Bottom" BorderBrush="#CFCFCF" BorderThickness="0,0,0,1"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="Border">
            <Setter Property="Background" Value="#FFF3E6CF"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Status pill -->
        <Style x:Key="StatusPill" TargetType="TextBlock">
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin"  Value="6,0,0,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Background" Value="#FFF1F1F1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#00000000" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Tag" Value="PREMIUM">
                    <Setter Property="Background" Value="#FFF9EED7"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#D9A566" BlurRadius="12" ShadowDepth="0" Opacity="0.9"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Style="{StaticResource SectionHeader}">
            <TextBlock Text="THBIM Licensing" FontWeight="Bold" FontSize="18"/>
        </Border>

        <!-- Profile -->
        <Border Grid.Row="1" BorderBrush="#E6D6B8" BorderThickness="1" CornerRadius="8" Padding="10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="👤" FontSize="16" Margin="0,0,8,0"/>
                <TextBlock x:Name="FullNameText" FontWeight="SemiBold"/>
                <TextBlock Text="  –  "/>
                <TextBlock x:Name="EmailText" Foreground="#555"/>
            </StackPanel>
        </Border>

        <!-- Current status -->
        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <Border Style="{StaticResource SectionHeader}">
                <TextBlock Text="Current Status" FontWeight="SemiBold"/>
            </Border>

            <Border BorderBrush="#E6D6B8" BorderThickness="1" CornerRadius="8" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="STATUS:" FontWeight="SemiBold"/>
                        <TextBlock x:Name="StatusPill" Style="{StaticResource StatusPill}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="EXPIRY:" FontWeight="SemiBold" Width="70"/>
                        <TextBlock x:Name="ExpireText" Text="-" Style="{StaticResource ExpireTextStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="MACHINE:" FontWeight="SemiBold" Width="70"/>
                        <TextBlock x:Name="MachineText"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Send Feedback" Margin="8,0,0,0"
                                Style="{StaticResource GhostButton}" Click="Feedback_Click"/>
                        <Button Content="Sign Out" Margin="8,0,0,0"
                                Style="{StaticResource GhostButton}" Click="Logout_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Activate license key -->
        <StackPanel Grid.Row="3" Margin="0,12,0,0">
            <Border Style="{StaticResource SectionHeader}">
                <TextBlock Text="Activate License Key" FontWeight="SemiBold"/>
            </Border>

            <Border BorderBrush="#E6D6B8" BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel>
                    <TextBlock Text="Enter license key (Free or Premium):" FontWeight="SemiBold"/>
                    <Border Margin="0,6,0,0" Padding="8" Background="White"
                            BorderBrush="#E9E0A7" BorderThickness="1" CornerRadius="6">
                        <TextBox x:Name="KeyBox" Style="{StaticResource UnderlinedTextBox}"
                                 BorderThickness="0" Height="30"/>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button x:Name="ActivateBtn" Content="Activate" Width="110" Margin="8,0,0,0"
                                Style="{StaticResource PrimaryButton}" Click="Activate_Click"/>
                    </StackPanel>

                    <TextBlock x:Name="ResultMsg" Margin="0,12,0,0"
                               Foreground="#2E7D32" Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Footer note -->
        <TextBlock Grid.Row="4" x:Name="FooterNote" Foreground="#777"/>

        <!-- Busy overlay -->
        <Grid x:Name="BusyOverlay" Visibility="Collapsed" Background="#66000000">
            <Border Background="White" CornerRadius="8" Padding="16" Width="320"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="#DDD" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="BusyTitle" Text="Processing…"
                               FontWeight="SemiBold" Margin="0,0,0,10"
                               HorizontalAlignment="Center"/>
                    <Grid Height="6" MinWidth="240">
                        <Border Background="#EEE" CornerRadius="3"/>
                        <Border Background="{StaticResource Primary}" CornerRadius="3">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="BusyScale" ScaleX="0" ScaleY="0.5"/>
                            </Border.RenderTransform>
                            <Border.RenderTransformOrigin>0,0.5</Border.RenderTransformOrigin>
                        </Border>
                    </Grid>
                    <TextBlock x:Name="BusyNote" Text="Please wait a moment"
                               Foreground="#777" Margin="0,10,0,0"
                               FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
