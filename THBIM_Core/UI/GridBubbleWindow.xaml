<Window x:Class="GridBubble.GridBubbleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GridBubble OptionBar" Height="25" Width="740"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False"
        Topmost="True" Background="Transparent" ShowActivated="False"
        AllowsTransparency="True">
    <Border CornerRadius="0" Margin="0"
          Background="#FFFFF6D7"
          BorderBrush="{x:Null}" BorderThickness="0"
          SnapsToDevicePixels="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="232.333"/>
                <ColumnDefinition Width="37.41"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="29*"/>
                <ColumnDefinition Width="357*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,377,0" Grid.ColumnSpan="5">
                <RadioButton x:Name="RbHide"
                      PreviewMouseLeftButtonDown="RbHide_PreviewMouseLeftButtonDown"
                      GroupName="Mode"
                      Content="Hide Grid/Level Bubbles"
                      Margin="0,0,18,0"
                      VerticalAlignment="Center"
                      Focusable="False"
                      Checked="RbHide_Checked" Click="RbHide_Click"/>
                <RadioButton x:Name="RbShow"
                      PreviewMouseLeftButtonDown="RbShow_PreviewMouseLeftButtonDown"        
                      GroupName="Mode"
                      Content="Show Grid/Level Bubbles"
                      VerticalAlignment="Center"
                      Focusable="False"
                      Checked="RbShow_Checked" Click="RbShow_Click"/>
            </StackPanel>

            <TextBlock Grid.Column="4" VerticalAlignment="Center" Margin="59,0,-78,0"
                 Text="Select Hide/Show to start • Switch mode during picks • ESC to exit"
                 Foreground="#AA333333" FontStyle="Italic"/>
        </Grid>
    </Border>
</Window>