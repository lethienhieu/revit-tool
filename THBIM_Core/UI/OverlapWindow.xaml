<Window x:Class="THBIM.OverlapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Single Category Overlap Check" Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        Topmost="True" 
        Background="#F5F5F5">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#D49A6A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C08558"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Target Category:" FontWeight="Bold" Foreground="#333" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbCategories" DisplayMemberPath="Name" SelectedValuePath="BIC" SelectionChanged="CmbCategories_SelectionChanged" />

            <TextBlock Text="Logic: Joined OR Intersection > 100mm" FontSize="11" FontStyle="Italic" Foreground="Gray" Margin="0,0,0,10"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="5" Margin="0,5,0,15">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="0" Opacity="0.1"/>
            </Border.Effect>

            <TreeView x:Name="tvResults" BorderThickness="0" SelectedItemChanged="TvResults_SelectedItemChanged" >
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Items}">
                        <TextBlock Text="{Binding GroupName}" FontWeight="Bold" Foreground="#D49A6A" Margin="0,5"/>

                        <HierarchicalDataTemplate.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2" Width="280">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="■" Foreground="Red" FontSize="10" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1" Text="{Binding Id}" Foreground="Gray" FontStyle="Italic" FontSize="11" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="2" Text="{Binding ElementName}" Foreground="#333" VerticalAlignment="Center" 
                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding ElementName}"/>
                                </Grid>
                            </DataTemplate>
                        </HierarchicalDataTemplate.ItemTemplate>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Border>

        <StackPanel Grid.Row="2">
            <Button x:Name="btnScan" Content="Scan Category &amp; Highlight" Click="BtnScan_Click"/>
            <Button x:Name="btnShow" Content="Show Selected Element" Click="BtnShow_Click" Background="#777"/>
        </StackPanel>
    </Grid>
</Window>