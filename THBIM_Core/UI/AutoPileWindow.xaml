<Window x:Class="THBIM.AutoPileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auto Pile Settings"
        Height="456" Width="460" 
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#FFF9F7F0"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="Primary" Color="#D9A566"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#C68C3E"/>
        <SolidColorBrush x:Key="TextGray" Color="#555555"/>
        <SolidColorBrush x:Key="LightBorder" Color="#FFE6D6B8"/>

        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#999" BlurRadius="10" ShadowDepth="2" Opacity="0.25"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderBar" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="CornerRadius" Value="8,8,0,0"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryDark}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#B57B2E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#6c757d"/>
            <Setter Property="BorderBrush" Value="#5a6268"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Border Style="{StaticResource SectionCard}" Margin="10,9,10,11">
            <DockPanel>
                <Border Style="{StaticResource HeaderBar}" DockPanel.Dock="Top">
                    <TextBlock Text="AUTO PILE CONFIGURATION" Foreground="White" FontWeight="Bold" FontSize="15"/>
                </Border>

                <Grid Margin="25,15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="15"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Select Pile Type:" Foreground="{StaticResource TextGray}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox Grid.Row="1" x:Name="cmbFamilies" Height="38" Padding="10,0" VerticalContentAlignment="Center" DisplayMemberPath="DisplayName" SelectionChanged="CmbFamilies_SelectionChanged" FontSize="13"/>

                    <TextBlock Grid.Row="3" Text="Override Length (Optional):" Foreground="{StaticResource TextGray}" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" x:Name="cmbParameters" Height="38" Padding="10,0" VerticalContentAlignment="Center" DisplayMemberPath="Name" IsEnabled="False" FontSize="13"/>
                        <Border Grid.Column="2" BorderBrush="#FFACACAC" BorderThickness="1" CornerRadius="4">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right" Text="mm" VerticalAlignment="Center" Margin="5,0" Foreground="Gray" FontSize="11"/>
                                <TextBox x:Name="txtParamValue" Height="36" VerticalContentAlignment="Center" Padding="5,0" BorderThickness="0" FontSize="13" Background="Transparent"/>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="2" BorderBrush="#FFACACAC" BorderThickness="1" CornerRadius="4"/>
                    </Grid>

                    <CheckBox Grid.Row="10" x:Name="chkIsLink" 
                              Content="Select elements from Linked Model"
                              IsChecked="False" 
                              Margin="0,19,0,40"
                              FontSize="13" FontWeight="SemiBold"
                              VerticalContentAlignment="Center"
                              Cursor="Hand"/>

                    <Button Grid.Row="10" x:Name="btnApply" 
                            Content="START PICKING (MANUAL)" 
                            Style="{StaticResource PrimaryButton}" 
                            Height="50" FontSize="15" FontWeight="Bold"
                            Click="BtnApply_Click"
                            Margin="0,52,0,-27"/>
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</Window>