<Window x:Class="THBIM.CustomNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custom File Name Builder" Height="500" Width="800" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#CCC" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Available Parameters" Background="#EEE" Padding="5" TextAlignment="Center"/>
                    <TextBox x:Name="TxtSearch" Grid.Row="1" Margin="5" Padding="2" TextChanged="TxtSearch_TextChanged" />
                    <ListBox x:Name="LstAvailable" Grid.Row="2" Margin="5" DisplayMemberPath="ParameterName" SelectionMode="Extended" MouseDoubleClick="LstAvailable_MouseDoubleClick"/>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button x:Name="BtnAdd" Content="▶" Width="30" Height="30" Margin="0,0,0,10" Click="BtnAdd_Click" ToolTip="Add to Name"/>
                <Button x:Name="BtnRemove" Content="◀" Width="30" Height="30" Click="BtnRemove_Click" ToolTip="Remove from Name"/>
            </StackPanel>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="DgNamingRules" Grid.Row="0" AutoGenerateColumns="False" CanUserAddRows="False" Margin="0,0,0,5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Parameter Name" Binding="{Binding ParameterName}" IsReadOnly="True" Width="120"/>
                        <DataGridTextColumn Header="Prefix" Binding="{Binding Prefix, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                        <DataGridTextColumn Header="Sample Value" Binding="{Binding SampleValue}" IsReadOnly="True" Width="120"/>
                        <DataGridTextColumn Header="Suffix" Binding="{Binding Suffix, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                        <DataGridTextColumn Header="Separator" Binding="{Binding Separator, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5,0,0">
                    <Button Content="▲" Width="30" Height="25" Margin="0,0,5,0" Click="BtnMoveUp_Click"/>
                    <Button Content="▼" Width="30" Height="25" Margin="0,0,5,0" Click="BtnMoveDown_Click"/>
                </StackPanel>
            </Grid>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,15,0,15">
            <TextBlock Text="Custom Name Preview: " FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock x:Name="TxtPreview" Text="" VerticalAlignment="Center" Foreground="#2980B9" FontSize="14" FontWeight="SemiBold"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Height="30" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button Content="OK" Width="80" Height="30" IsDefault="True" Background="#2980B9" Foreground="White" Click="BtnOk_Click"/>
        </StackPanel>
    </Grid>
</Window>