<Window x:Class="THBIM.THBIMSheetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="THBIM - ProSheets" Height="750" Width="1100"
        Background="#F4F4F4" WindowStartupLocation="CenterScreen" FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- ── Icon Button (title bar) ── -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width"  Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background"      Value="#3A3A3A"/>
            <Setter Property="BorderBrush"     Value="#555555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="#CCCCCC"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A4A4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Profile ComboBox ── -->
        <Style x:Key="ProfileCmb" TargetType="ComboBox">
            <Setter Property="Width"  Value="140"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background"  Value="#4A4A4A"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="BorderBrush" Value="#666666"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding"     Value="5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#1A1A1A"/>
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Padding" Value="4,2"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#FFF3CC"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1" CornerRadius="3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="18"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="1" Text="▾" FontSize="10"
                                                           Foreground="#CCCCCC"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="6,0,20,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                      SnapsToDevicePixels="True">
                                    <Border x:Name="DropDownBorder"
                                            Background="White"
                                            BorderBrush="#D0D0D0"
                                            BorderThickness="1"
                                            CornerRadius="0,0,3,3">
                                        <ScrollViewer Margin="2" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleButton" Property="Background" Value="#FFF3CC"/>
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="#E8C45A"/>
                                <Setter TargetName="ContentSite" Property="TextBlock.Foreground" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#2A2A2A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabButtonStyle" TargetType="RadioButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1,1,1,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="#DDD" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#2980B9"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormatGroupBox" TargetType="GroupBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderBrush" Value="#DEDEDE"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="#555" FontWeight="SemiBold" Margin="5,0"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormatToggleBtnStyle" TargetType="RadioButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="BorderBrush" Value="#E67E22"/>
                                <Setter Property="Foreground" Value="#E67E22"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F9F9F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="55"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2B2B2B" BorderBrush="#444444" BorderThickness="0,0,0,1">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <TextBlock Grid.Column="0" VerticalAlignment="Center"
                           FontSize="18" FontWeight="Bold">
                    <Run Foreground="White">TH</Run><Run Foreground="#E8830A">BIM</Run>
                </TextBlock>

                <!-- Title -->
                <TextBlock Grid.Column="1"
                           Text="ProSheet"
                           Foreground="#CCCCCC" FontSize="13"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <!-- Right: Profile + controls -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <!-- Profile label -->
                    <TextBlock Text="👤 Profile"
                               Foreground="#AAAAAA" FontSize="12"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>

                    <!-- Profile dropdown -->
                    <ComboBox x:Name="CboProfiles"
                              Style="{StaticResource ProfileCmb}"
                              Margin="0,0,4,0"
                              SelectionChanged="CboProfiles_SelectionChanged"/>

                    <!-- Import Profile -->
                    <Button Content="📥"
                            Style="{StaticResource IconBtn}"
                            Margin="0,0,3,0"
                            ToolTip="Import Profile"
                            Click="BtnImportProfile_Click"/>

                    <!-- Save Profile -->
                    <Button x:Name="BtnSaveProfile"
                            Content="💾"
                            Style="{StaticResource IconBtn}"
                            Margin="0,0,3,0"
                            ToolTip="Save Profile"
                            Click="BtnSaveProfile_Click"/>

                    <!-- Delete Profile -->
                    <Button Content="🗑"
                            Style="{StaticResource IconBtn}"
                            Margin="0,0,6,0"
                            ToolTip="Delete Profile"
                            Click="BtnDeleteProfile_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="15,5,15,0">
            <RadioButton x:Name="TabSelection" Content="Selection" Style="{StaticResource TabButtonStyle}" IsChecked="True" Checked="Tab_Checked" />
            <RadioButton x:Name="TabFormat" Content="Format" Style="{StaticResource TabButtonStyle}" Margin="2,0" Checked="Tab_Checked" PreviewMouseDown="TabFormat_PreviewMouseDown"/>
            <RadioButton x:Name="TabCreate" Content="Create" Style="{StaticResource TabButtonStyle}" Checked="Tab_Checked" PreviewMouseDown="TabFormat_PreviewMouseDown"/>
        </StackPanel>

        <TabControl Grid.Row="2" Background="White" BorderBrush="#DDD" Margin="15,0,15,5" SelectionChanged="TabControl_SelectionChanged">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <ContentPresenter ContentSource="SelectedContent"/>
                </ControlTemplate>
            </TabControl.Template>

            <TabItem IsSelected="{Binding IsChecked, ElementName=TabSelection}">
                <Grid Background="White">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="10,5">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <RadioButton x:Name="RbSheets" Content="Sheets" IsChecked="True" Margin="0,0,10,0" VerticalAlignment="Center" Checked="RbToggle_Checked"/>
                            <RadioButton x:Name="RbViews" Content="Views" VerticalAlignment="Center" Margin="0,0,20,0" Checked="RbToggle_Checked"/>

                            <TextBlock Text="View/Sheet Set" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#555"/>

                            <ComboBox x:Name="CboSets" Width="200" Height="28" Margin="0,0,10,0" 
                                      VerticalContentAlignment="Center" DisplayMemberPath="Name"
                                      SelectionChanged="CboSets_SelectionChanged"/>

                            <ComboBox x:Name="CboSaveSet" Width="130" Height="28" Background="#FDCB6E" BorderThickness="0" 
          VerticalContentAlignment="Center" SelectionChanged="CboSaveSet_SelectionChanged">
                                <ComboBoxItem Content="Save V/S Set" FontWeight="SemiBold" IsSelected="True" Visibility="Collapsed"/>

                                <ComboBoxItem Content="New Set"/>
                                <ComboBoxItem Content="Add to Existing"/>
                                <ComboBoxItem Content="Delete Set"/>
                            </ComboBox>
                        </StackPanel>

                        <Border BorderBrush="#CCC" BorderThickness="1" HorizontalAlignment="Right" Width="250" Height="28" Background="White" CornerRadius="2">
                            <Grid>
                                <TextBox x:Name="TxtSearch" TextChanged="TxtSearch_TextChanged" BorderThickness="0" VerticalContentAlignment="Center" Margin="8,0,30,0" />
                                <TextBlock Text="🔍" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#AAA" IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <DataGrid x:Name="DgSheets" Grid.Row="1" ItemsSource="{Binding SheetItems}" 
                              AutoGenerateColumns="False" CanUserAddRows="False" 
                              RowHeight="32" GridLinesVisibility="All" 
                              HorizontalGridLinesBrush="#EEE" VerticalGridLinesBrush="#EEE" 
                              HeadersVisibility="Column" BorderThickness="0,1,0,0"
                              SelectionUnit="FullRow" SelectionMode="Extended">

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="40">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <CheckBox Click="HeaderCheckBox_Click" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Select All"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Click="RowCheckBox_Click" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn x:Name="ColSheetNumber" Header="Sheet Number" Binding="{Binding SheetNumber}" Width="Auto" IsReadOnly="True"/>

                            <DataGridTextColumn x:Name="ColName" Header="Sheet Name" Binding="{Binding SheetName}" Width="1*" MinWidth="150" IsReadOnly="True"/>

                            <DataGridTextColumn x:Name="ColRevision" Header="Revision" Binding="{Binding Revision}" Width="Auto" IsReadOnly="True"/>
                            <DataGridTextColumn x:Name="ColSize" Header="Size" Binding="{Binding PaperSize}" Width="Auto" IsReadOnly="True"/>

                            <DataGridTemplateColumn x:Name="ColViewType" Width="130">
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <Border Background="#FDCB6E" CornerRadius="2" Padding="5,0">
                                            <ComboBox ItemsSource="{Binding DataContext.ViewTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      SelectedItem="{Binding DataContext.SelectedViewType, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                                      SelectionChanged="CboViewType_SelectionChanged"
                                                      Width="110" Height="24" BorderThickness="0" Background="Transparent" Foreground="#333" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ViewType}" VerticalAlignment="Center" Margin="5,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn x:Name="ColViewScale" Header="View Scale" Binding="{Binding ViewScale}" Width="90" IsReadOnly="True" />
                            <DataGridTextColumn x:Name="ColDetailLevel" Header="Detail Level" Binding="{Binding DetailLevel}" Width="100" IsReadOnly="True" />
                            <DataGridTextColumn x:Name="ColDiscipline" Header="Discipline" Binding="{Binding Discipline}" Width="130" IsReadOnly="True" />

                            <DataGridTemplateColumn Width="1*" MinWidth="150">
                                <DataGridTemplateColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0"/>
                                    </Style>
                                </DataGridTemplateColumn.HeaderStyle>
                                <DataGridTemplateColumn.HeaderTemplate>
                                    <DataTemplate>
                                        <Button Content="Custom File Name" 
                                                Background="#D6D6D6" Foreground="Black" 
                                                BorderThickness="1,0,0,0" BorderBrush="#AAA" 
                                                Cursor="Hand" 
                                                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                                Click="HeaderCustomNameBtn_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.HeaderTemplate>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding CustomFileName, UpdateSourceTrigger=PropertyChanged}" 
                                                 BorderThickness="0" Background="Transparent" 
                                                 VerticalContentAlignment="Center" Margin="5,0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem IsSelected="{Binding IsChecked, ElementName=TabFormat}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="White">
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5,0,0,25">
                            <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                <CheckBox x:Name="ChkExportPDF" IsChecked="True" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <RadioButton x:Name="RbViewPDF" GroupName="FormatViews" IsChecked="True" Style="{StaticResource FormatToggleBtnStyle}">
                                    <StackPanel>
                                        <TextBlock Text="📄" FontSize="24" HorizontalAlignment="Center"/>
                                        <TextBlock Text="PDF" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                <CheckBox x:Name="ChkExportDWG" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <RadioButton x:Name="RbViewDWG" GroupName="FormatViews" Style="{StaticResource FormatToggleBtnStyle}">
                                    <StackPanel>
                                        <TextBlock Text="⚙️" FontSize="24" HorizontalAlignment="Center"/>
                                        <TextBlock Text="DWG" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>
                        </StackPanel>

                        <Grid Grid.Row="1" Visibility="{Binding IsChecked, ElementName=RbViewPDF, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="320"/>
                                <ColumnDefinition Width="320"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <GroupBox Header="Paper Placement" Style="{StaticResource FormatGroupBox}">
                                    <StackPanel Margin="5">
                                        <RadioButton x:Name="RbCenter" Content="Center" IsChecked="True" Margin="0,5"/>
                                        <RadioButton x:Name="RbOffset" Content="Offset from corner" Margin="0,5"/>
                                        <StackPanel Orientation="Horizontal" Margin="25,0,0,5" IsEnabled="{Binding IsChecked, ElementName=RbOffset}">
                                            <TextBlock Text="X (mm):" VerticalAlignment="Center"/>
                                            <TextBox x:Name="TxtOffsetX" Width="40" Margin="5,0" Text="0.0"/>
                                            <TextBlock Text="Y (mm):" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                            <TextBox x:Name="TxtOffsetY" Width="40" Margin="5,0" Text="0.0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Header="Zoom" Style="{StaticResource FormatGroupBox}" Margin="0,5,0,0">
                                    <StackPanel Margin="5">
                                        <RadioButton x:Name="RbFitToPage" Content="Fit to Page" IsChecked="True" 
                     GroupName="PdfZoomGroup" Margin="0,5" Cursor="Hand"/>

                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton x:Name="RbZoom" Content="Zoom" 
                         GroupName="PdfZoomGroup" Margin="0,5" VerticalAlignment="Center" Cursor="Hand"/>

                                            <TextBox x:Name="TxtZoomPercentage" Text="100" Width="40" Height="22" Margin="10,0,5,0" 
                     VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                     IsEnabled="{Binding IsChecked, ElementName=RbZoom}"/>
                                            <TextBlock Text="%" VerticalAlignment="Center" Foreground="#555"/>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>



                                <GroupBox Header="Appearance" Style="{StaticResource FormatGroupBox}">
                                    <Grid Margin="5">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="35"/>
                                            <RowDefinition Height="35"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Raster Quality" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="CboRasterQuality" Grid.Column="1" Height="28" SelectedIndex="2">
                                            <ComboBoxItem Content="Low (72 DPI)"/>
                                            <ComboBoxItem Content="Medium (144 DPI)"/>
                                            <ComboBoxItem Content="High (300 DPI)"/>
                                            <ComboBoxItem Content="Presentation (600 DPI)"/>
                                        </ComboBox>

                                        <TextBlock Grid.Row="1" Text="Colors" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="CboColors" Grid.Row="1" Grid.Column="1" Height="28" SelectedIndex="0">
                                            <ComboBoxItem Content="Color"/>
                                            <ComboBoxItem Content="Black &amp; White"/>
                                            <ComboBoxItem Content="Grayscale"/>
                                        </ComboBox>
                                    </Grid>
                                </GroupBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <GroupBox Header="Options (Hide)" Style="{StaticResource FormatGroupBox}">
                                    <StackPanel Margin="5">
                                        <CheckBox x:Name="ChkHideRefPlanes" Content="Ref/Work planes" IsChecked="True" Margin="0,5"/>
                                        <CheckBox x:Name="ChkHideUnrefTags" Content="Unreferenced tags" IsChecked="True" Margin="0,5"/>
                                        <CheckBox x:Name="ChkHideCrop" Content="Crop boundaries" IsChecked="True" Margin="0,5"/>
                                        <CheckBox x:Name="ChkHideScopeBox" Content="Scope boxes" IsChecked="True" Margin="0,5"/>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <GroupBox Header="File Grouping" Style="{StaticResource FormatGroupBox}">
                                    <StackPanel Margin="5">
                                        <RadioButton x:Name="RbSeparate" Content="Create separate files" IsChecked="True" Margin="0,5"/>
                                        <RadioButton x:Name="RbCombine" Content="Combine into a single file" Margin="0,5"/>
                                        <Border BorderBrush="#DDD" BorderThickness="1" Margin="10,5,0,0" Padding="10" Background="#F9F9F9" 
                Visibility="{Binding IsChecked, ElementName=RbCombine, Converter={StaticResource BoolToVis}}">
                                            <StackPanel>
                                                <TextBlock Text="File Name:" Foreground="#555" Margin="0,0,0,5"/>
                                                <TextBox x:Name="TxtCombinedName" Height="28" Text="THBIM_Combined_Project" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

                                                <Button x:Name="BtnEditOrder" Content="⚙ Edit Sheet Order" Height="28" Background="#D6D6D6" BorderBrush="#AAA" BorderThickness="1" Cursor="Hand" Click="BtnEditOrder_Click"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" Visibility="{Binding IsChecked, ElementName=RbViewDWG, Converter={StaticResource BoolToVis}}">
                            <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                                <GroupBox Header="Select Export Setup" Style="{StaticResource FormatGroupBox}" Margin="0,0,0,15">
                                    <StackPanel Orientation="Horizontal" Margin="15,10">
                                        <TextBlock Text="Name" VerticalAlignment="Center" Width="60" Foreground="#333"/>

                                        <ComboBox x:Name="CboDwgExportSetup" Width="220" Height="28" 
                  VerticalContentAlignment="Center" DisplayMemberPath="Name"/>
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Header="Important Note" Style="{StaticResource FormatGroupBox}" Margin="0,0,0,15">
                                    <TextBlock Text="To Create an 'Export Group', go to 'DWG Export' and select 'Modify Export Setup' on the 'Select Export Setup' group box."
                                               TextWrapping="Wrap" Margin="15,10" Foreground="#555"/>
                                </GroupBox>

                                <CheckBox x:Name="ChkExportViewsOnSheets" Content="Export views on sheets and links as external references" Margin="5,5,0,15"/>

                                <StackPanel Orientation="Horizontal" Margin="5,5,0,5">
                                    <CheckBox x:Name="ChkBindImages" Content="Bind Images as OLE in DWG File" Margin="5,5,0,5" IsEnabled="False" Cursor="Hand"/>
                                    <TextBlock Text="⭐" Foreground="#FDCB6E" Margin="5,0,0,0"/>
                                </StackPanel>
                                <TextBlock Text="* This feature requires AutoCAD 2019 (or higher) to work." Foreground="#888" Margin="25,0,0,15" FontStyle="Italic"/>
                                

                                <StackPanel Orientation="Horizontal" Margin="5,5,0,5">
                                    <CheckBox x:Name="ChkCleanPcp" Content="Clean .pcp files after export" Margin="5,5,0,15" Cursor="Hand"/>
                                    <TextBlock Text="⭐" Foreground="#FDCB6E" Margin="5,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            <TabItem IsSelected="{Binding IsChecked, ElementName=TabCreate}">
                <Grid Background="White" Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Column="0" Header="Export Rules" Style="{StaticResource FormatGroupBox}" Margin="0,0,10,0">
                            <StackPanel Margin="10,5">
                                <TextBlock Text="Folder Selection" Foreground="#555" Margin="0,0,0,5"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtExportFolder" Height="26" VerticalContentAlignment="Center" Text="C:\Export\" Background="#FDFDFD" BorderBrush="#CCC"/>
                                    <Button x:Name="BtnBrowseFolder" Grid.Column="1" Content="..." Width="35" Height="26" Margin="5,0,0,0" Cursor="Hand" Background="#E0E0E0" BorderBrush="#CCC" Click="BtnBrowseFolder_Click"/>
                                </Grid>

                                

                                <RadioButton x:Name="RbSaveSameFolder" Content="Save all files in the same folder location" IsChecked="True" Margin="0,5"/>
                                <RadioButton x:Name="RbSaveSplitFormat" Content="Save and split files by file format" Margin="0,5"/>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Grid.Column="1" Header="Progress" Style="{StaticResource FormatGroupBox}" Margin="10,0,0,0">
                            <Grid Margin="10,25,10,10" VerticalAlignment="Top">
                                <ProgressBar x:Name="PbOverall" Height="32" Minimum="0" Maximum="100" Value="0" 
                                             Foreground="#7CB342" Background="#F9F9F9" BorderBrush="#CCC" BorderThickness="1"/>

                                <TextBlock x:Name="TxtOverallProgress" Text="Completed 0%" VerticalAlignment="Center" Margin="10,0" 
                                           Foreground="#333" FontWeight="SemiBold" IsHitTestVisible="False"/>
                            </Grid>
                        </GroupBox>
                    </Grid>

                    <Border Grid.Row="1" Background="#F5F5F5" BorderBrush="#CCC" BorderThickness="1,1,1,0" Padding="5">
                        <StackPanel Orientation="Horizontal">

                            <Border Background="White" BorderBrush="#CCC" BorderThickness="1" CornerRadius="2" Margin="0,0,10,0">
                                <Menu Background="Transparent" VerticalAlignment="Center">
                                    <MenuItem Header="Set Paper Size ▾" Padding="15,4" Foreground="#333">

                                        <MenuItem Header="A">
                                            <MenuItem Header="A0" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="A1" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="A2" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="A3" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="A4" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="A5" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="A6" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="A7" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="A8" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="A9" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="A10" Click="MenuPaperSize_Click"/>
                                        </MenuItem>

                                        <MenuItem Header="B">
                                            <MenuItem Header="ISO B0" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="ISO B1" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="ISO B2" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="ISO B3" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="ISO B4" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="ISO B5" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="ISO B6" Click="MenuPaperSize_Click"/>
                                        </MenuItem>

                                        <MenuItem Header="ARCH">
                                            <MenuItem Header="ARCH A" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="ARCH B" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="ARCH C" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="ARCH D" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="ARCH E" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="ARCH E1" Click="MenuPaperSize_Click"/>
                                        </MenuItem>

                                        <MenuItem Header="ANSI">
                                            <MenuItem Header="ANSI A" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="ANSI B" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="ANSI C" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="ANSI D" Click="MenuPaperSize_Click"/>
                                            <MenuItem Header="ANSI E" Click="MenuPaperSize_Click"/>
                                        </MenuItem>

                                        <MenuItem Header="Other">
                                            <MenuItem Header="Custom" Click="MenuPaperSize_Click"/>
                                        </MenuItem>

                                    </MenuItem>
                                </Menu>
                            </Border>

                            <Border Background="White" BorderBrush="#CCC" BorderThickness="1" CornerRadius="2">
                                <Menu Background="Transparent" VerticalAlignment="Center">
                                    <MenuItem Header="Set Orientation ▾" Padding="15,4" Foreground="#333">
                                        <MenuItem Header="Landscape" Click="MenuOrientation_Click"/>
                                        <MenuItem Header="Portrait" Click="MenuOrientation_Click"/>
                                    </MenuItem>
                                </Menu>
                            </Border>

                        </StackPanel>
                    </Border>
                    <DataGrid x:Name="DgCreate" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" 
                              RowHeight="32" GridLinesVisibility="All" 
                              HorizontalGridLinesBrush="#EEE" VerticalGridLinesBrush="#EEE" 
                              HeadersVisibility="Column" BorderThickness="1" BorderBrush="#CCC"
                              Background="White" SelectionMode="Extended">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="View/Sheet Number" Binding="{Binding SheetNumber}" Width="160" IsReadOnly="True"/>
                            <DataGridTextColumn Header="View/Sheet Name" Binding="{Binding SheetName}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Format" Binding="{Binding ExportFormat}" Width="80" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding PaperSize}" Width="80" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Orientation" Binding="{Binding Orientation}" Width="100" IsReadOnly="True"/>

                            <DataGridTemplateColumn Header="Progress" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border x:Name="ProgressBg" Margin="0" Padding="10,0">
                                            <TextBlock x:Name="StatusText" 
                           VerticalAlignment="Center" 
                           FontSize="11" 
                           Foreground="#333"/>
                                        </Border>

                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding ExportStatus}" Value="Pending">
                                                <Setter TargetName="StatusText" Property="Text" Value=""/>
                                                <Setter TargetName="ProgressBg" Property="Background" Value="Transparent"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding ExportStatus}" Value="Exporting...">
                                                <Setter TargetName="StatusText" Property="Text" Value="Publishing..."/>
                                                <Setter TargetName="ProgressBg" Property="Background" Value="#FFF9C4"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding ExportStatus}" Value="Success">
                                                <Setter TargetName="StatusText" Property="Text" Value="Successfully published."/>
                                                <Setter TargetName="ProgressBg" Property="Background" Value="#A5D6A7"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding ExportStatus}" Value="Error">
                                                <Setter TargetName="StatusText" Property="Text" Value="Failed to publish."/>
                                                <Setter TargetName="ProgressBg" Property="Background" Value="#FFCDD2"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>
            </TabItem>



        </TabControl>

        <Border Grid.Row="3" Background="#E9E9E9" BorderBrush="#DDD" BorderThickness="0,1,0,0">
            <Grid Margin="15,0">
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtCount" Text="0 sheets selected" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="#666"/>
                    <Button x:Name="BtnBack" Content="Back" Width="90" Height="32" Margin="5,0" Click="BtnBack_Click" IsEnabled="False"/>
                    <Button x:Name="BtnNext" Content="Next" Width="90" Height="32" Background="#2980B9" Foreground="White" BorderThickness="0" Margin="5,0" Click="BtnNext_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        <Grid x:Name="LoadingOverlay" Grid.RowSpan="4" Background="#D8FFFFFF" Visibility="Collapsed" Panel.ZIndex="999">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="TxtLoadingStatus" Text="Loading Sheets/Views... Please wait" FontSize="16" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                <ProgressBar x:Name="PbLoading" Width="400" Height="5" Minimum="0" Maximum="100"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>