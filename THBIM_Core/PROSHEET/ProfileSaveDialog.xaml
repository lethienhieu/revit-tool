<Window x:Class="THBIM.ProfileSaveDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save Profile" Height="220" Width="420"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Border Background="#E0E0E0" CornerRadius="8" BorderBrush="#AAA" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" VerticalAlignment="Center">
                <TextBlock Text="This profile will be updated with" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="#333"/>
                <TextBlock Text="- Custom Drawing Number" Margin="5,2" Foreground="#555"/>
                <TextBlock Text="- Format options" Margin="5,2" Foreground="#555"/>
                <TextBlock Text="  PDF, DWG" FontSize="11" Margin="5,0,0,0" Foreground="#777"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button Content="Save As" Width="90" Height="32" Margin="0,0,10,0" 
                        Background="#BDBDBD" Foreground="#333" BorderThickness="0" 
                        Cursor="Hand" Click="BtnSaveAs_Click"/>

                <Button Content="Save" Width="90" Height="32" Margin="0,0,10,0"
                        Background="#2980B9" Foreground="White" FontWeight="Bold" BorderThickness="0" 
                        Cursor="Hand" Click="BtnSave_Click"/>

                <Button Content="Close" Width="80" Height="32" 
                        Background="Transparent" Foreground="#666" BorderThickness="1" BorderBrush="#AAA"
                        Cursor="Hand" Click="BtnCancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>