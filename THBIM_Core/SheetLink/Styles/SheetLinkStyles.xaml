<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════
         COLORS
    ═══════════════════════════════════════════ -->
    <Color x:Key="AccentColor">#E8830A</Color>
    <Color x:Key="AccentDarkColor">#D07508</Color>
    <Color x:Key="TitleBarColor">#2B2B2B</Color>
    <Color x:Key="TitleBarSurfaceColor">#3A3A3A</Color>
    <Color x:Key="BgColor">#F0F0F0</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="Surface2Color">#F7F7F7</Color>
    <Color x:Key="BorderColor">#D0D0D0</Color>
    <Color x:Key="Border2Color">#E0E0E0</Color>
    <Color x:Key="TextColor">#1A1A1A</Color>
    <Color x:Key="Text2Color">#555555</Color>
    <Color x:Key="Text3Color">#888888</Color>
    <Color x:Key="ToolbarColor">#F4F4F4</Color>
    <Color x:Key="HeaderColor">#F0F0F0</Color>
    <Color x:Key="TabActiveColor">#FFFFFF</Color>
    <Color x:Key="TabInactiveColor">#D0D0D0</Color>

    <!-- Parameter type colors -->
    <Color x:Key="InstanceBgColor">#EAF3DE</Color>
    <Color x:Key="InstanceFgColor">#4A7C2F</Color>
    <Color x:Key="InstanceBorderColor">#B5D98A</Color>
    <Color x:Key="TypeBgColor">#FDF0CC</Color>
    <Color x:Key="TypeFgColor">#8A6010</Color>
    <Color x:Key="TypeBorderColor">#E8C45A</Color>
    <Color x:Key="ReadOnlyBgColor">#FDEAEA</Color>
    <Color x:Key="ReadOnlyFgColor">#922222</Color>
    <Color x:Key="ReadOnlyBorderColor">#E8A0A0</Color>

    <!-- Button colors -->
    <Color x:Key="BtnExportColor">#2A6E2A</Color>
    <Color x:Key="BtnExportHoverColor">#1A5A1A</Color>
    <Color x:Key="BtnPreviewColor">#FFF8E8</Color>
    <Color x:Key="BtnPreviewFgColor">#7A5500</Color>

    <!-- ═══════════════════════════════════════════
         BRUSHES
    ═══════════════════════════════════════════ -->
    <SolidColorBrush x:Key="AccentBrush"          Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentDarkBrush"       Color="{StaticResource AccentDarkColor}"/>
    <SolidColorBrush x:Key="TitleBarBrush"         Color="{StaticResource TitleBarColor}"/>
    <SolidColorBrush x:Key="TitleBarSurfaceBrush"  Color="{StaticResource TitleBarSurfaceColor}"/>
    <SolidColorBrush x:Key="BgBrush"               Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush"          Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="Surface2Brush"         Color="{StaticResource Surface2Color}"/>
    <SolidColorBrush x:Key="BorderBrush"           Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="Border2Brush"          Color="{StaticResource Border2Color}"/>
    <SolidColorBrush x:Key="TextBrush"             Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="Text2Brush"            Color="{StaticResource Text2Color}"/>
    <SolidColorBrush x:Key="Text3Brush"            Color="{StaticResource Text3Color}"/>
    <SolidColorBrush x:Key="ToolbarBrush"          Color="{StaticResource ToolbarColor}"/>
    <SolidColorBrush x:Key="HeaderBrush"           Color="{StaticResource HeaderColor}"/>

    <SolidColorBrush x:Key="InstanceBgBrush"       Color="{StaticResource InstanceBgColor}"/>
    <SolidColorBrush x:Key="InstanceFgBrush"       Color="{StaticResource InstanceFgColor}"/>
    <SolidColorBrush x:Key="InstanceBorderBrush"   Color="{StaticResource InstanceBorderColor}"/>
    <SolidColorBrush x:Key="TypeBgBrush"           Color="{StaticResource TypeBgColor}"/>
    <SolidColorBrush x:Key="TypeFgBrush"           Color="{StaticResource TypeFgColor}"/>
    <SolidColorBrush x:Key="TypeBorderBrush"       Color="{StaticResource TypeBorderColor}"/>
    <SolidColorBrush x:Key="ReadOnlyBgBrush"       Color="{StaticResource ReadOnlyBgColor}"/>
    <SolidColorBrush x:Key="ReadOnlyFgBrush"       Color="{StaticResource ReadOnlyFgColor}"/>
    <SolidColorBrush x:Key="ReadOnlyBorderBrush"   Color="{StaticResource ReadOnlyBorderColor}"/>
    <SolidColorBrush x:Key="BtnExportBrush"        Color="{StaticResource BtnExportColor}"/>
    <SolidColorBrush x:Key="BtnPreviewBrush"       Color="{StaticResource BtnPreviewColor}"/>
    <SolidColorBrush x:Key="BtnPreviewFgBrush"     Color="{StaticResource BtnPreviewFgColor}"/>

    <!-- ═══════════════════════════════════════════
         TYPOGRAPHY
    ═══════════════════════════════════════════ -->
    <FontFamily x:Key="MainFont">Segoe UI</FontFamily>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeSmall">11</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeNormal">12.5</System:Double>
    <System:Double xmlns:System="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeLarge">13</System:Double>

    <!-- ═══════════════════════════════════════════
         SCROLLBAR STYLE
    ═══════════════════════════════════════════ -->
    <Style x:Key="SlScrollBarThumb" TargetType="Thumb">
        <Setter Property="Background" Value="#C0C0C0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="{TemplateBinding Background}" CornerRadius="3" Margin="1"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#A0A0A0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SlScrollBar" TargetType="ScrollBar">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Background" Value="#F0F0F0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid>
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource SlScrollBarThumb}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SlScrollViewer" TargetType="ScrollViewer">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ScrollContentPresenter Grid.Column="0"/>
                        <ScrollBar Grid.Column="1"
                                   Style="{StaticResource SlScrollBar}"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════
         TEXTBOX - SEARCH
    ═══════════════════════════════════════════ -->
    <Style x:Key="SearchBoxStyle" TargetType="TextBox">
        <Setter Property="FontFamily"        Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="Foreground"        Value="{StaticResource TextBrush}"/>
        <Setter Property="Background"        Value="White"/>
        <Setter Property="BorderBrush"       Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness"   Value="1"/>
        <Setter Property="Padding"           Value="4,2"/>
        <Setter Property="Height"            Value="24"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                            <TextBlock x:Name="placeholder"
                                       Text="{TemplateBinding Tag}"
                                       Foreground="{StaticResource Text3Brush}"
                                       FontSize="12"
                                       Margin="5,0,22,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="Collapsed"/>
                            <TextBlock Text="🔍" HorizontalAlignment="Right"
                                       Margin="0,0,4,0" VerticalAlignment="Center"
                                       Foreground="{StaticResource Text3Brush}"
                                       FontSize="11" IsHitTestVisible="False"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════
         COMBOBOX
    ═══════════════════════════════════════════ -->
    <Style x:Key="SlComboBox" TargetType="ComboBox">
        <Setter Property="FontFamily"      Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Height"          Value="26"/>
        <Setter Property="Foreground"      Value="{StaticResource TextBrush}"/>
        <Setter Property="Background"      Value="White"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="5,2"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- ═══════════════════════════════════════════
         CHECKBOX
    ═══════════════════════════════════════════ -->
    <Style x:Key="SlCheckBox" TargetType="CheckBox">
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Margin"     Value="0,0,4,0"/>
    </Style>

    <!-- ═══════════════════════════════════════════
         RADIO BUTTON
    ═══════════════════════════════════════════ -->
    <Style x:Key="SlRadioButton" TargetType="RadioButton">
        <Setter Property="FontFamily" Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize"   Value="12.5"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Margin"     Value="0,0,12,0"/>
    </Style>

    <!-- ═══════════════════════════════════════════
         COLUMN HEADER (3-panel layout)
    ═══════════════════════════════════════════ -->
    <Style x:Key="ColHeaderStyle" TargetType="Border">
        <Setter Property="Background"       Value="{StaticResource HeaderBrush}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness"  Value="0,0,0,1"/>
        <Setter Property="Height"           Value="30"/>
        <Setter Property="Padding"          Value="8,0"/>
    </Style>

    <Style x:Key="ColHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize"    Value="12"/>
        <Setter Property="FontWeight"  Value="Medium"/>
        <Setter Property="Foreground"  Value="{StaticResource Text2Brush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ═══════════════════════════════════════════
         LIST ITEM (category rows)
    ═══════════════════════════════════════════ -->
    <Style x:Key="ListItemStyle" TargetType="Border">
        <Setter Property="Height"     Value="22"/>
        <Setter Property="Padding"    Value="8,0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor"     Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F0F6FF"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════
         ARROW BUTTON (◀ ▶)
    ═══════════════════════════════════════════ -->
    <Style x:Key="ArrowBtnStyle" TargetType="Button">
        <Setter Property="Width"            Value="26"/>
        <Setter Property="Height"           Value="26"/>
        <Setter Property="Background"       Value="#E0E0E0"/>
        <Setter Property="BorderBrush"      Value="#BBBBBB"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Foreground"       Value="{StaticResource Text2Brush}"/>
        <Setter Property="FontSize"         Value="11"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#CCCCCC"/>
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#BBBBBB"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════
         SORT BUTTON (↑ ↓)
    ═══════════════════════════════════════════ -->
    <Style x:Key="SortBtnStyle" TargetType="Button">
        <Setter Property="Width"           Value="22"/>
        <Setter Property="Height"          Value="22"/>
        <Setter Property="Background"      Value="#E0E0E0"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize"        Value="9"/>
        <Setter Property="Foreground"      Value="{StaticResource Text2Brush}"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#CCCCCC"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#BBBBBB"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════
         TOOLBAR ACTION BUTTON
    ═══════════════════════════════════════════ -->
    <Style x:Key="ToolbarBtnStyle" TargetType="Button">
        <Setter Property="Height"          Value="26"/>
        <Setter Property="Padding"         Value="10,0"/>
        <Setter Property="Background"      Value="#E8E8E8"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground"      Value="{StaticResource TextBrush}"/>
        <Setter Property="FontFamily"      Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#DDDDDD"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════
         ACTION BAR BUTTONS
    ═══════════════════════════════════════════ -->
    <!-- Reset / Normal -->
    <Style x:Key="ActBtnStyle" TargetType="Button">
        <Setter Property="Height"          Value="30"/>
        <Setter Property="Padding"         Value="14,0"/>
        <Setter Property="Background"      Value="#E0E0E0"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground"      Value="{StaticResource TextBrush}"/>
        <Setter Property="FontFamily"      Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize"        Value="12.5"/>
        <Setter Property="FontWeight"      Value="Medium"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#D0D0D0"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="#C0C0C0"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Preview/Edit button -->
    <Style x:Key="PreviewBtnStyle" TargetType="Button" BasedOn="{StaticResource ActBtnStyle}">
        <Setter Property="Background"  Value="{StaticResource BtnPreviewBrush}"/>
        <Setter Property="BorderBrush" Value="#D4AA40"/>
        <Setter Property="Foreground"  Value="{StaticResource BtnPreviewFgBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FDF0CC"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Import / Export (green) -->
    <Style x:Key="ImportBtnStyle" TargetType="Button" BasedOn="{StaticResource ActBtnStyle}">
        <Setter Property="Background"  Value="{StaticResource BtnExportBrush}"/>
        <Setter Property="BorderBrush" Value="#1A5A1A"/>
        <Setter Property="Foreground"  Value="White"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#1A5A1A"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="#AACCAA"/>
                <Setter Property="BorderBrush" Value="#99BB99"/>
                <Setter Property="Opacity" Value="1"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Export Template (Spatial) -->
    <Style x:Key="ExportTemplateBtnStyle" TargetType="Button" BasedOn="{StaticResource ImportBtnStyle}"/>

    <!-- Feedback pill buttons -->
    <Style x:Key="FeedbackBtnStyle" TargetType="Button">
        <Setter Property="Height"          Value="28"/>
        <Setter Property="Padding"         Value="14,0"/>
        <Setter Property="Background"      Value="#2A8A2A"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily"      Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize"        Value="12"/>
        <Setter Property="FontWeight"      Value="Medium"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="14"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1A7A1A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="UniqueNeedBtnStyle" TargetType="Button" BasedOn="{StaticResource FeedbackBtnStyle}">
        <Setter Property="Background" Value="#0088AA"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#006688"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════
         PARAMETER LEGEND BADGES
    ═══════════════════════════════════════════ -->
    <Style x:Key="BadgeBaseStyle" TargetType="Border">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Padding" Value="7,2"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform Y="0"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" BlurRadius="4" ShadowDepth="0" Opacity="0.16"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TranslateTransform Y="-1"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#000000" BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="InstanceBadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
        <Setter Property="Background" Value="{StaticResource InstanceBgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource InstanceBorderBrush}"/>
    </Style>

    <Style x:Key="TypeBadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
        <Setter Property="Background" Value="{StaticResource TypeBgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource TypeBorderBrush}"/>
    </Style>

    <Style x:Key="ReadOnlyBadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgeBaseStyle}">
        <Setter Property="Background" Value="{StaticResource ReadOnlyBgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ReadOnlyBorderBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════════
         SECTION DIVIDER
    ═══════════════════════════════════════════ -->
    <Style x:Key="HDivider" TargetType="Border">
        <Setter Property="Height"          Value="1"/>
        <Setter Property="Background"      Value="{StaticResource BorderBrush}"/>
        <Setter Property="Margin"          Value="0"/>
    </Style>

    <Style x:Key="VDivider" TargetType="Border">
        <Setter Property="Width"           Value="1"/>
        <Setter Property="Background"      Value="{StaticResource BorderBrush}"/>
    </Style>

    <!-- ═══════════════════════════════════════════
         STATUS BAR TEXT
    ═══════════════════════════════════════════ -->
    <Style x:Key="StatusTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="{StaticResource MainFont}"/>
        <Setter Property="FontSize"    Value="11.5"/>
        <Setter Property="Foreground"  Value="{StaticResource Text2Brush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ═══════════════════════════════════════════
         ICON BUTTON (profile toolbar)
    ═══════════════════════════════════════════ -->
    <Style x:Key="IconBtnStyle" TargetType="Button">
        <Setter Property="Width"           Value="26"/>
        <Setter Property="Height"          Value="26"/>
        <Setter Property="Background"      Value="#3A3A3A"/>
        <Setter Property="BorderBrush"     Value="#555555"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground"      Value="#CCCCCC"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#4A4A4A"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
