<UserControl x:Class="THBIM.ModelCategoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1100"
             Background="#FFFFFF"
             FontFamily="Segoe UI"
             FontSize="12">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/THBIM;component/SheetLink/Styles/SheetLinkStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

        <Style x:Key="SbThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#C0C0C0" CornerRadius="3" Margin="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SbBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SbThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SbViewer" TargetType="ScrollViewer">
            <Setter Property="CanContentScroll" Value="True"/>
            <Setter Property="PanningMode" Value="VerticalFirst"/>
        </Style>

        <Style x:Key="Cb" TargetType="CheckBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
        </Style>

        <Style x:Key="Rb" TargetType="RadioButton">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,14,0"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
        </Style>

        <Style x:Key="Sb" TargetType="TextBox">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="5,0,22,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ToolTip" Value="Search"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <Grid>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Right" Margin="0,0,5,0"
                                           VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="12" IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#E8830A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Cmb" TargetType="ComboBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF3CC"/>
                    <Setter Property="BorderBrush" Value="#E8C45A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="Ab" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CCCCCC"/>
                            </Trigger>
                            <Trigger Property="IsPressed"   Value="True">
                                <Setter Property="Background" Value="#BBBBBB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Srt" TargetType="Button">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Tb" TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#DDDDDD"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"   Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsPressed"   Value="True">
                                <Setter Property="Background" Value="#C0C0C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrevBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#FFF8E8"/>
            <Setter Property="BorderBrush" Value="#D4AA40"/>
            <Setter Property="Foreground" Value="#7A5500"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FDF0CC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#2A6E2A"/>
            <Setter Property="BorderBrush" Value="#1A5A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A5A1A"/>
                </Trigger>
                <Trigger Property="IsEnabled"   Value="False">
                    <Setter Property="Background" Value="#AACCAA"/>
                    <Setter Property="BorderBrush" Value="#99BB99"/>
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="Row" TargetType="Border">
            <Setter Property="Height" Value="22"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F6FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="28"/>
            <RowDefinition Height="44"/>
        </Grid.RowDefinitions>

        <!-- â•â• ROW 0: TOOLBAR â•â• -->
        <Border Grid.Row="0" Background="#F4F4F4" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1">
            <Grid Margin="10,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton x:Name="RbWholeModel"
                                 Content="Whole Model"
                                 GroupName="ScopeMdl"
                                 IsChecked="True"
                                 Style="{StaticResource Rb}"
                                 Checked="Scope_Checked"/>
                    <RadioButton x:Name="RbActiveView"
                                 Content="Active View"
                                 GroupName="ScopeMdl"
                                 Style="{StaticResource Rb}"
                                 Checked="Scope_Checked"/>
                    <RadioButton x:Name="RbCurrentSelection"
                                 Content="Current Selection"
                                 GroupName="ScopeMdl"
                                 Style="{StaticResource Rb}"
                                 Checked="Scope_Checked"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- 3D Section Box -->
                    <Button Width="28" Height="28" Style="{StaticResource Tb}" Padding="0"
                            ToolTip="3D Section Box" Margin="0,0,6,0" Click="BtnSectionBox_Click">
                          <TextBlock Text="⬡" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="BtnIsolate" Content="Isolate Selection"
                            Style="{StaticResource Tb}" IsEnabled="False" Margin="0,0,6,0"
                            Click="BtnIsolate_Click"/>
                    <Button Content="Export Project Standards"
                            Style="{StaticResource Tb}" Click="BtnExportProjectStandards_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- â•â• ROW 1: 3-COLUMN â•â• -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="36"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- COL 0: SELECT CATEGORIES -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Padding="8,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="ChkAll" Style="{StaticResource Cb}" Click="ChkAll_Click"/>
                        <TextBlock Text="Select Categories" FontSize="12" FontWeight="Medium" Foreground="#555555" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <ComboBox Grid.Row="1" x:Name="CbDisc" Style="{StaticResource Cmb}" Margin="6,2" IsEditable="True" IsReadOnly="True" Text="&lt;All Disciplines&gt;"/>

                <TextBox Grid.Row="2" x:Name="TbSrchCat" Style="{StaticResource Sb}" Margin="6,2" TextChanged="TbSrchCat_TextChanged"/>

                <ScrollViewer Grid.Row="3" Style="{StaticResource SbViewer}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="SpCat"/>
                </ScrollViewer>

                <Border Grid.Row="4" Background="#FAFAFA" BorderBrush="#E8E8E8" BorderThickness="0,1,0,0" Padding="8,0">
                    <CheckBox x:Name="ChkHide" Content="Hide un-checked categories" Style="{StaticResource Cb}" Click="ChkHide_Click"/>
                </Border>
            </Grid>

            <!-- VERTICAL DIVIDER -->
            <Border Grid.Column="1" Background="#D0D0D0"/>

            <!-- COL 2: AVAILABLE PARAMETERS -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="36"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Padding="8,0">
                    <TextBlock Text="Available Parameters" FontSize="12" FontWeight="Medium" Foreground="#555555" VerticalAlignment="Center"/>
                </Border>

                <ComboBox Grid.Row="1" x:Name="CbParamFilter" Style="{StaticResource Cmb}" Margin="6,2" IsEditable="True" IsReadOnly="True" Text="Instance, Type, Read-only">
                    <CheckBox x:Name="ChkAvailInstance" Content="Instance" IsChecked="True" Style="{StaticResource Cb}" Margin="4,2" Click="ParamFilter_CheckedChanged"/>
                    <CheckBox x:Name="ChkAvailType" Content="Type" IsChecked="True" Style="{StaticResource Cb}" Margin="4,2" Click="ParamFilter_CheckedChanged"/>
                    <CheckBox x:Name="ChkAvailReadOnly" Content="Read-only" IsChecked="True" Style="{StaticResource Cb}" Margin="4,2" Click="ParamFilter_CheckedChanged"/>
                </ComboBox>

                <TextBox Grid.Row="2" x:Name="TbSrchAvail" Style="{StaticResource Sb}" Margin="6,2" TextChanged="TbSrchAvail_TextChanged"/>

                <ScrollViewer Grid.Row="3" Style="{StaticResource SbViewer}" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="SpAvail"/>
                </ScrollViewer>

                <Border Grid.Row="4"
                        Background="#F4F4F4"
                        BorderBrush="#D0D0D0"
                        BorderThickness="0,1,0,0" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="6,0">
                        <Border Style="{StaticResource InstanceBadgeStyle}" Margin="0,0,4,0" MouseLeftButtonDown="BadgeInst_Click">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="8" Height="8" Fill="#4A7C2F" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="Instance" FontSize="11.5" FontWeight="Medium" Foreground="#4A7C2F"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource TypeBadgeStyle}" Margin="0,0,4,0" MouseLeftButtonDown="BadgeType_Click">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="8" Height="8" Fill="#8A6010" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="Type" FontSize="11.5" FontWeight="Medium" Foreground="#8A6010"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource ReadOnlyBadgeStyle}" Margin="0,0,0,0" MouseLeftButtonDown="BadgeRo_Click">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="8" Height="8" Fill="#922222" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="Read-only" FontSize="11.5" FontWeight="Medium" Foreground="#922222"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- COL 3: ARROWS -->
            <Border Grid.Column="3" Background="#F4F4F4" BorderBrush="#D0D0D0" BorderThickness="1,0">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                     <Button Content="▶" Style="{StaticResource Ab}" Margin="0,0,0,6" ToolTip="Add"    Click="BtnRight_Click"/>
                     <Button Content="◀" Style="{StaticResource Ab}"                   ToolTip="Remove" Click="BtnLeft_Click"/>
                </StackPanel>
            </Border>

            <!-- COL 4: SELECTED PARAMETERS -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Padding="8,0">
                    <TextBlock Text="Selected Parameters" FontSize="12" FontWeight="Medium" Foreground="#555555" VerticalAlignment="Center"/>
                </Border>

                <ComboBox Grid.Row="1" x:Name="CbSelParamFilter" Style="{StaticResource Cmb}" Margin="6,2" IsEditable="True" IsReadOnly="True" Text="Instance, Type, Read-only">
                    <CheckBox x:Name="ChkSelInstance" Content="Instance" IsChecked="True" Style="{StaticResource Cb}" Margin="4,2" Click="SelParamFilter_CheckedChanged"/>
                    <CheckBox x:Name="ChkSelType" Content="Type" IsChecked="True" Style="{StaticResource Cb}" Margin="4,2" Click="SelParamFilter_CheckedChanged"/>
                    <CheckBox x:Name="ChkSelReadOnly" Content="Read-only" IsChecked="True" Style="{StaticResource Cb}" Margin="4,2" Click="SelParamFilter_CheckedChanged"/>
                </ComboBox>

                <TextBox Grid.Row="2" x:Name="TbSrchSel" Style="{StaticResource Sb}" Margin="6,2" TextChanged="TbSrchSel_TextChanged"/>

                <ScrollViewer Grid.Row="3" Style="{StaticResource SbViewer}" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="SpSel"/>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- â•â• ROW 2: LEGEND + SORT â•â• -->
        <Border Grid.Row="2" Background="#F4F4F4" BorderBrush="#D0D0D0" BorderThickness="0,1,0,0">
            <Grid Margin="8,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox x:Name="ChkLinked"   Content="Include Linked Files" Style="{StaticResource Cb}" Margin="0,0,14,0"/>
                    <CheckBox x:Name="ChkByTypeId" Content="Export by Type ID"    Style="{StaticResource Cb}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="⏫" Style="{StaticResource Srt}" Margin="0,0,2,0" ToolTip="Move to top"    Click="SrtTop_Click"/>
                    <Button Content="🔼" Style="{StaticResource Srt}" Margin="0,0,2,0" ToolTip="Move up"        Click="SrtUp_Click"/>
                    <Button Content="🔽" Style="{StaticResource Srt}" Margin="0,0,2,0" ToolTip="Move down"      Click="SrtDown_Click"/>
                    <Button Content="⏬" Style="{StaticResource Srt}" Margin="0,0,2,0" ToolTip="Move to bottom" Click="SrtBot_Click"/>
                    <Button Content="↺"  Style="{StaticResource Srt}" FontSize="13"    ToolTip="Reset sort"     Click="SrtReset_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- â•â• ROW 3: STATUS BAR â•â• -->
        <Border Grid.Row="3" Background="#E8E8E8" BorderBrush="#D0D0D0" BorderThickness="0,1,0,0" Padding="10,0">
            <TextBlock x:Name="TbStatus"
                       Text="Model categories selected 0 | parameters found 0 | parameters selected 0"
                       FontSize="11.5" Foreground="#555555" VerticalAlignment="Center"/>
        </Border>

        <!-- â•â• ROW 4: ACTION BAR â•â• -->
        <Border Grid.Row="4" Background="#F0F0F0" BorderBrush="#D0D0D0" BorderThickness="0,1,0,0" Padding="10,0">
            <Grid VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="Reset Values" Style="{StaticResource Btn}"     Margin="0,0,6,0" Click="BtnReset_Click"/>
                    <Button x:Name="BtnPreview" Content="Preview/Edit" Style="{StaticResource PrevBtn}" Margin="0,0,6,0"
                            IsEnabled="False" Click="BtnPreview_Click"/>
                                        <ComboBox x:Name="CbImportAction" Style="{StaticResource Cmb}" Height="30" Width="170" Margin="0,0,6,0"
                              SelectionChanged="CbImportAction_SelectionChanged">
                        <ComboBoxItem Content="Import" IsSelected="True"/>
                        <ComboBoxItem Content="Import from Excel"/>
                        <ComboBoxItem Content="Import from Google"/>
                        <ComboBoxItem Content="Preview Import"/>
                    </ComboBox>
                    <Button x:Name="BtnExport" Content="Export" Style="{StaticResource GBtn}" IsEnabled="False" Click="BtnExport_Click"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>

