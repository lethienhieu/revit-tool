                           FontSize="14" Foreground="#2A2A2A" VerticalAlignment="Center" Margin="8,0,0,0"/>

                <Border Grid.Row="2" Grid.Column="0" Background="#FDEAEA" BorderBrush="#D0D0D0" BorderThickness="1,1,1,0"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="Read-only value"
                           FontSize="14" Foreground="#2A2A2A" VerticalAlignment="Center" Margin="8,0,0,0"/>

                <Border Grid.Row="3" Grid.Column="0" Background="#D0D0D0" BorderBrush="#D0D0D0" BorderThickness="1"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="Parameter does not exist for this element"
                           FontSize="14" Foreground="#2A2A2A" VerticalAlignment="Center" Margin="8,0,0,0"/>

                <TextBlock Grid.Row="5" Grid.ColumnSpan="2" Text="Note:"
                           FontSize="14" FontWeight="SemiBold" Foreground="#2A2A2A" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="6" Grid.ColumnSpan="2"
                           Text="To create new Rooms or Spaces you should add new rows of information. Provide a minimum of Number, Name, and Phase parameter values to create correctly Rooms and Spaces."
                           TextWrapping="Wrap"
                           FontSize="14" Foreground="#2A2A2A" VerticalAlignment="Center"/>
                <TextBlock Grid.Row="7" Grid.ColumnSpan="2"
                           Text="Please don't input values to the GUID(hidden) and Element ID columns for new rows. Revit will automatically assign GUID and Element ID when elements are created."
                           TextWrapping="Wrap"
                           FontSize="14" Foreground="#2A2A2A" VerticalAlignment="Center"/>
