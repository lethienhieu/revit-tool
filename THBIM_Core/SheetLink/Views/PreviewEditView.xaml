                        Foreground="#555555" FontSize="10" Cursor="Hand"
                        Click="BtnSheetLeft_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="2" Width="18" Height="18">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#CCCCCC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="◀" FontSize="9" VerticalAlignment="Center"/>
                </Button>

                <Button Width="18" Height="18" Background="Transparent" BorderThickness="0"
                        Foreground="#555555" FontSize="10" Cursor="Hand" Margin="1,0,4,0"
                        Click="BtnSheetRight_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="2" Width="18" Height="18">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#CCCCCC"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="▶" FontSize="9" VerticalAlignment="Center"/>
                </Button>

                <!-- Active sheet tab -->
                <Border x:Name="TabRooms"
                        Style="{StaticResource SheetTab}"
                        Background="White"
                        MouseLeftButtonDown="SheetTab_Click" Tag="Rooms">
                    <TextBlock Text="Rooms" FontSize="12" FontWeight="Medium"
                               Foreground="#1A1A1A" VerticalAlignment="Center"/>
                </Border>

                <!-- Instructions tab -->
                <Border x:Name="TabInstructions"
                        Style="{StaticResource SheetTab}"
                        MouseLeftButtonDown="SheetTab_Click" Tag="Instructions">
                    <TextBlock Text="Instructions" FontSize="12"
                               Foreground="#555555" VerticalAlignment="Center"/>
                </Border>

                <!-- Add new sheet button -->
                <Border Height="22" Width="22" Margin="2,0,0,0"
                        BorderBrush="#AAAAAA" BorderThickness="1"
                        CornerRadius="2" Cursor="Hand" Background="Transparent"
                        MouseLeftButtonDown="BtnAddSheet_Click">
                    <TextBlock Text="+" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="#888888"/>
                </Border>

            </StackPanel>
        </Border>

