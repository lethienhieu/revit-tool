<UserControl x:Class="THBIM.PreviewEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1100"
             Background="#FFFFFF"
             FontFamily="Segoe UI"
             FontSize="12">

    <UserControl.Resources>

        <!-- Scrollbar -->
        <Style x:Key="SbThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#C0C0C0" CornerRadius="3" Margin="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SbBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SbThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action buttons -->
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsPressed"   Value="True">
                                <Setter Property="Background" Value="#C0C0C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Update Model green button -->
        <Style x:Key="GBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#2A6E2A"/>
            <Setter Property="BorderBrush" Value="#1A5A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A5A1A"/>
                </Trigger>
                <Trigger Property="IsEnabled"   Value="False">
                    <Setter Property="Background" Value="#AACCAA"/>
                    <Setter Property="BorderBrush" Value="#99BB99"/>
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Sheet tab -->
        <Style x:Key="SheetTab" TargetType="Border">
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="Background"      Value="#D0D0D0"/>
            <Setter Property="BorderBrush"     Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="1,1,1,0"/>
            <Setter Property="Margin"          Value="1,0,0,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8E8E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Grid header cell (yellow) -->
        <Style x:Key="GridHeaderCell" TargetType="Border">
            <Setter Property="Background"      Value="#FDF0CC"/>
            <Setter Property="BorderBrush"     Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="MinWidth"        Value="140"/>
        </Style>

        <!-- Row number cell -->
        <Style x:Key="RowNumCell" TargetType="Border">
            <Setter Property="Background"      Value="#E8E8E8"/>
            <Setter Property="BorderBrush"     Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Width"           Value="32"/>
        </Style>

        <!-- Column letter header -->
        <Style x:Key="ColLetterCell" TargetType="Border">
            <Setter Property="Background"      Value="#D0D0D0"/>
            <Setter Property="BorderBrush"     Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Height"          Value="20"/>
        </Style>

        <!-- Data cell -->
        <Style x:Key="DataCell" TargetType="Border">
            <Setter Property="BorderBrush"     Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Height"          Value="20"/>
            <Setter Property="MinWidth"        Value="140"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF3CC"/>
                    <Setter Property="BorderBrush" Value="#E8C45A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>
            <!-- Collecting progress -->
            <RowDefinition Height="*"/>
            <!-- Grid area -->
            <RowDefinition Height="28"/>
            <!-- Sheet tabs -->
            <RowDefinition Height="44"/>
            <!-- Action bar -->
        </Grid.RowDefinitions>

        <!-- ══ ROW 0: COLLECTING PROGRESS ══ -->
        <Border Grid.Row="0"
                Background="#F4F4F4"
                BorderBrush="#D0D0D0"
                BorderThickness="0,0,0,1"
                Padding="8,3">
            <Border x:Name="ProgressFill"
                    Background="#C8EEC8"
                    CornerRadius="3"
                    HorizontalAlignment="Stretch">
                <TextBlock x:Name="TbProgress"
                           Text="[1/1] Collecting data [1/1 categories] 100%"
                           Foreground="#1A6A1A"
                           FontSize="12" FontWeight="Medium"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </Border>

        <!-- ══ ROW 1: EXCEL-LIKE GRID ══ -->
        <ScrollViewer x:Name="RoomsSheetScroll"
                      Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="White">
            <Grid x:Name="GridContainer">
                <Grid.RowDefinitions>
                    <!-- Col-letter header row -->
                    <RowDefinition Height="20"/>
                    <!-- Param header row (yellow, tall) -->
                    <RowDefinition Height="56"/>
                    <!-- Data rows — add more in code-behind -->
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="20"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <!-- Row number col -->
                    <ColumnDefinition Width="32"/>
                    <!-- Data columns -->
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <!-- ── ROW 0: Column letters ── -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource ColLetterCell}">
                    <TextBlock Text="" FontSize="11" Foreground="#888888"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource ColLetterCell}">
                    <TextBlock Text="B" FontSize="11" Foreground="#555555" FontWeight="Medium"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource ColLetterCell}">
                    <TextBlock Text="C" FontSize="11" Foreground="#555555" FontWeight="Medium"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="3" Style="{StaticResource ColLetterCell}">
                    <TextBlock Text="D" FontSize="11" Foreground="#555555" FontWeight="Medium"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="4" Style="{StaticResource ColLetterCell}">
                    <TextBlock Text="E" FontSize="11" Foreground="#555555" FontWeight="Medium"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="5" Style="{StaticResource ColLetterCell}">
                    <TextBlock Text="F" FontSize="11" Foreground="#555555" FontWeight="Medium"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="6" Style="{StaticResource ColLetterCell}">
                    <TextBlock Text="G" FontSize="11" Foreground="#555555" FontWeight="Medium"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="0" Grid.Column="7" Style="{StaticResource ColLetterCell}">
                    <TextBlock Text="H" FontSize="11" Foreground="#555555" FontWeight="Medium"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- ── ROW 1: Parameter headers (yellow) ── -->
                <!-- Row number header -->
                <Border Grid.Row="1" Grid.Column="0"
                        Background="#D0D0D0"
                        BorderBrush="#BBBBBB"
                        BorderThickness="0,0,1,1"/>

                <!-- Element ID -->
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource GridHeaderCell}">
                    <StackPanel Margin="0,2,0,0" VerticalAlignment="Top">
                        <TextBlock Text="Element ID" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#333333" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="Custom Parameter" FontSize="10.5" Foreground="#888888"/>
                        <TextBlock Text="Instance"         FontSize="10.5" Foreground="#888888"/>
                        <ComboBox Height="18" Margin="0,2,4,0" FontSize="10"
                                  BorderBrush="#D0D0D0" Background="White">
                            <ComboBoxItem Content="▼" IsSelected="True"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Number -->
                <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource GridHeaderCell}">
                    <StackPanel Margin="0,2,0,0" VerticalAlignment="Top">
                        <TextBlock Text="Number"  FontSize="12" FontWeight="SemiBold"
                                   Foreground="#333333" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="String"  FontSize="10.5" Foreground="#888888"/>
                        <TextBlock Text="Instance" FontSize="10.5" Foreground="#888888"/>
                        <ComboBox Height="18" Margin="0,2,4,0" FontSize="10"
                                  BorderBrush="#D0D0D0" Background="White">
                            <ComboBoxItem Content="▼" IsSelected="True"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Name -->
                <Border Grid.Row="1" Grid.Column="3" Style="{StaticResource GridHeaderCell}">
                    <StackPanel Margin="0,2,0,0" VerticalAlignment="Top">
                        <TextBlock Text="Name"    FontSize="12" FontWeight="SemiBold"
                                   Foreground="#333333" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="String"  FontSize="10.5" Foreground="#888888"/>
                        <TextBlock Text="Instance" FontSize="10.5" Foreground="#888888"/>
                        <ComboBox Height="18" Margin="0,2,4,0" FontSize="10"
                                  BorderBrush="#D0D0D0" Background="White">
                            <ComboBoxItem Content="▼" IsSelected="True"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Phase -->
                <Border Grid.Row="1" Grid.Column="4" Style="{StaticResource GridHeaderCell}">
                    <StackPanel Margin="0,2,0,0" VerticalAlignment="Top">
                        <TextBlock Text="Phase"    FontSize="12" FontWeight="SemiBold"
                                   Foreground="#333333" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="ElementId" FontSize="10.5" Foreground="#888888"/>
                        <TextBlock Text="Instance"  FontSize="10.5" Foreground="#888888"/>
                        <ComboBox Height="18" Margin="0,2,4,0" FontSize="10"
                                  BorderBrush="#D0D0D0" Background="White">
                            <ComboBoxItem Content="▼" IsSelected="True"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Base Finish -->
                <Border Grid.Row="1" Grid.Column="5" Style="{StaticResource GridHeaderCell}">
                    <StackPanel Margin="0,2,0,0" VerticalAlignment="Top">
                        <TextBlock Text="Base Finish" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#333333" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="String"      FontSize="10.5" Foreground="#888888"/>
                        <TextBlock Text="Instance"    FontSize="10.5" Foreground="#888888"/>
                        <ComboBox Height="18" Margin="0,2,4,0" FontSize="10"
                                  BorderBrush="#D0D0D0" Background="White">
                            <ComboBoxItem Content="▼" IsSelected="True"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Floor Finish -->
                <Border Grid.Row="1" Grid.Column="6" Style="{StaticResource GridHeaderCell}">
                    <StackPanel Margin="0,2,0,0" VerticalAlignment="Top">
                        <TextBlock Text="Floor Finish" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#333333" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="String"       FontSize="10.5" Foreground="#888888"/>
                        <TextBlock Text="Instance"     FontSize="10.5" Foreground="#888888"/>
                        <ComboBox Height="18" Margin="0,2,4,0" FontSize="10"
                                  BorderBrush="#D0D0D0" Background="White">
                            <ComboBoxItem Content="▼" IsSelected="True"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- Area (Read-only — pink bg) -->
                <Border Grid.Row="1" Grid.Column="7"
                        Background="#FDEAEA"
                        BorderBrush="#D0D0D0"
                        BorderThickness="0,0,1,1"
                        Padding="6,4"
                        MinWidth="140">
                    <StackPanel Margin="0,2,0,0" VerticalAlignment="Top">
                        <TextBlock Text="Area"      FontSize="12" FontWeight="SemiBold"
                                   Foreground="#333333" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="Double"    FontSize="10.5" Foreground="#888888"/>
                        <TextBlock Text="Read-only" FontSize="10.5" Foreground="#922222"/>
                        <ComboBox Height="18" Margin="0,2,4,0" FontSize="10"
                                  BorderBrush="#D0D0D0" Background="#FDEAEA">
                            <ComboBoxItem Content="▼" IsSelected="True"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- ── DATA ROWS (rows 2–24) ── -->
                <!-- Row 2 -->
                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource RowNumCell}">
                    <TextBlock Text="2" FontSize="11" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource DataCell}">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0"/>
                </Border>
                <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource DataCell}">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0"/>
                </Border>
                <Border Grid.Row="2" Grid.Column="3" Style="{StaticResource DataCell}">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0"/>
                </Border>
                <Border Grid.Row="2" Grid.Column="4" Style="{StaticResource DataCell}">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0"/>
                </Border>
                <Border Grid.Row="2" Grid.Column="5" Style="{StaticResource DataCell}">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0"/>
                </Border>
                <Border Grid.Row="2" Grid.Column="6" Style="{StaticResource DataCell}">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0"/>
                </Border>
                <Border Grid.Row="2" Grid.Column="7" Background="#FFF5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1" Height="20" MinWidth="140">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0" IsReadOnly="True"/>
                </Border>

                <!-- Row 3 -->
                <Border Grid.Row="3" Grid.Column="0" Style="{StaticResource RowNumCell}">
                    <TextBlock Text="3" FontSize="11" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource DataCell}">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0"/>
                </Border>
                <Border Grid.Row="3" Grid.Column="2" Style="{StaticResource DataCell}">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0"/>
                </Border>
                <Border Grid.Row="3" Grid.Column="3" Style="{StaticResource DataCell}">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0"/>
                </Border>
                <Border Grid.Row="3" Grid.Column="4" Style="{StaticResource DataCell}">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0"/>
                </Border>
                <Border Grid.Row="3" Grid.Column="5" Style="{StaticResource DataCell}">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0"/>
                </Border>
                <Border Grid.Row="3" Grid.Column="6" Style="{StaticResource DataCell}">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0"/>
                </Border>
                <Border Grid.Row="3" Grid.Column="7" Background="#FFF5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1" Height="20" MinWidth="140">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0" IsReadOnly="True"/>
                </Border>

                <!-- Row 4 -->
                <Border Grid.Row="4" Grid.Column="0" Style="{StaticResource RowNumCell}">
                    <TextBlock Text="4" FontSize="11" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="4" Grid.Column="1" Style="{StaticResource DataCell}">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0"/>
                </Border>
                <Border Grid.Row="4" Grid.Column="2" Style="{StaticResource DataCell}">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0"/>
                </Border>
                <Border Grid.Row="4" Grid.Column="3" Style="{StaticResource DataCell}">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0"/>
                </Border>
                <Border Grid.Row="4" Grid.Column="4" Style="{StaticResource DataCell}">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0"/>
                </Border>
                <Border Grid.Row="4" Grid.Column="5" Style="{StaticResource DataCell}">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0"/>
                </Border>
                <Border Grid.Row="4" Grid.Column="6" Style="{StaticResource DataCell}">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0"/>
                </Border>
                <Border Grid.Row="4" Grid.Column="7" Background="#FFF5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1" Height="20" MinWidth="140">
                    <TextBox Text="" BorderThickness="0" Background="Transparent" FontSize="12" VerticalContentAlignment="Center" Padding="4,0" IsReadOnly="True"/>
                </Border>

                <!-- Rows 5-24: empty editable cells -->
                <Border Grid.Row="5"  Grid.Column="0" Style="{StaticResource RowNumCell}">
                    <TextBlock Text="5"  FontSize="11" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="5"  Grid.Column="1" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="5"  Grid.Column="2" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="5"  Grid.Column="3" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="5"  Grid.Column="4" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="5"  Grid.Column="5" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="5"  Grid.Column="6" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="5"  Grid.Column="7" Background="#FFF5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1" Height="20" MinWidth="140"/>

                <Border Grid.Row="6"  Grid.Column="0" Style="{StaticResource RowNumCell}">
                    <TextBlock Text="6"  FontSize="11" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="6"  Grid.Column="1" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="6"  Grid.Column="2" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="6"  Grid.Column="3" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="6"  Grid.Column="4" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="6"  Grid.Column="5" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="6"  Grid.Column="6" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="6"  Grid.Column="7" Background="#FFF5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1" Height="20" MinWidth="140"/>

                <Border Grid.Row="7"  Grid.Column="0" Style="{StaticResource RowNumCell}">
                    <TextBlock Text="7"  FontSize="11" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="7"  Grid.Column="1" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="7"  Grid.Column="2" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="7"  Grid.Column="3" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="7"  Grid.Column="4" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="7"  Grid.Column="5" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="7"  Grid.Column="6" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="7"  Grid.Column="7" Background="#FFF5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1" Height="20" MinWidth="140"/>

                <Border Grid.Row="8"  Grid.Column="0" Style="{StaticResource RowNumCell}">
                    <TextBlock Text="8"  FontSize="11" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="8"  Grid.Column="1" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="8"  Grid.Column="2" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="8"  Grid.Column="3" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="8"  Grid.Column="4" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="8"  Grid.Column="5" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="8"  Grid.Column="6" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="8"  Grid.Column="7" Background="#FFF5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,1" Height="20" MinWidth="140"/>

                <Border Grid.Row="9"  Grid.Column="0" Style="{StaticResource RowNumCell}">
                    <TextBlock Text="9"  FontSize="11" Foreground="#888888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Row="9"  Grid.Column="1" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="9"  Grid.Column="2" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="9"  Grid.Column="3" Style="{StaticResource DataCell}"/>
                <Border Grid.Row="9"  Grid.Column="4" Style="{StaticResource DataCell}"/>
