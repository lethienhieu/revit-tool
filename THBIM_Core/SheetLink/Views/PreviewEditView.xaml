                           FontSize="14" FontWeight="SemiBold" Foreground="#2A2A2A" VerticalAlignment="Center"/>

                <Border Grid.Row="1" Grid.Column="0" Background="#FDF0CC" BorderBrush="#D0D0D0" BorderThickness="1,1,1,0"/>
